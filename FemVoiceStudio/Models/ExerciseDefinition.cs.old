using System;
using System.Collections.Generic;

namespace FemVoiceStudio.Models
{
    /// <summary>
    /// Brukernivå basert på erfaring og prestasjon
    /// </summary>
    public enum UserLevel
    {
        Nybegynner = 1,
        Middels = 2,
        Avansert = 3
    }
    
    /// <summary>
    /// Målområde for en stemmeparameter
    /// </summary>
    public class TargetRange
    {
        public double Min { get; set; }
        public double Max { get; set; }
        
        public TargetRange() { }
        
        public TargetRange(double min, double max)
        {
            Min = min;
            Max = max;
        }
        
        /// <summary>
        /// Sjekk om en verdi er innenfor målområdet
        /// </summary>
        public bool IsInRange(double value)
        {
            return value >= Min && value <= Max;
        }
        
        /// <summary>
        /// Beregn avstand fra målområdet
        /// </summary>
        public double DistanceFromRange(double value)
        {
            if (IsInRange(value)) return 0;
            if (value < Min) return Min - value;
            return value - Max;
        }
    }
    
    /// <summary>
    /// Skaleringsfaktorer for ulike brukernivåer
    /// </summary>
    public class LevelScalingFactors
    {
        public double PitchToleranceMultiplier { get; set; } = 1.0;
        public double ResonanceToleranceMultiplier { get; set; } = 1.0;
        public double StabilityThresholdMultiplier { get; set; } = 1.0;
        public double FeedbackIntervalSeconds { get; set; } = 5.0;
        public double HintDetailLevel { get; set; } = 1.0; // 1=detaljert, 0.5=mindre, 0=minimal
        
        /// <summary>
        /// Standard skaleringsfaktorer for nybegynner
        /// </summary>
        public static LevelScalingFactors ForNybegynner()
        {
            return new LevelScalingFactors
            {
                PitchToleranceMultiplier = 2.0,      // ±15 Hz istedet for ±8 Hz
                ResonanceToleranceMultiplier = 2.0,    // ±200 Hz istedet for ±100 Hz
                StabilityThresholdMultiplier = 2.0,     // jitter <3% istedet for <2%
                FeedbackIntervalSeconds = 5.0,          // Hver 5. sekund
                HintDetailLevel = 1.0                  // Detaljerte hints
            };
        }
        
        /// <summary>
        /// Standard skaleringsfaktorer for middels
        /// </summary>
        public static LevelScalingFactors ForMiddels()
        {
            return new LevelScalingFactors
            {
                PitchToleranceMultiplier = 1.0,       // ±8 Hz
                ResonanceToleranceMultiplier = 1.0,    // ±100 Hz
                StabilityThresholdMultiplier = 1.0,    // jitter <2%
                FeedbackIntervalSeconds = 10.0,        // Hver 10. sekund
                HintDetailLevel = 0.7                  // Balansert veiledning
            };
        }
        
        /// <summary>
        /// Standard skaleringsfaktorer for avansert
        /// </summary>
        public static LevelScalingFactors ForAvansert()
        {
            return new LevelScalingFactors
            {
                PitchToleranceMultiplier = 0.5,       // ±4 Hz
                ResonanceToleranceMultiplier = 0.5,    // ±50 Hz
                StabilityThresholdMultiplier = 0.75,   // jitter <1.5%
                FeedbackIntervalSeconds = 999.0,       // Kun ved feil
                HintDetailLevel = 0.3                  // Minimal veiledning
            };
        }
    }
    
    /// <summary>
    /// Helsebeskyttelsesterskler for en øvelse
    /// </summary>
    public class HealthProtectionThresholds
    {
        public double MaxJitterPercent { get; set; } = 2.5;
        public double MaxShimmerPercent { get; set; } = 4.0;
        public double MaxAmplitudeSpikePercent { get; set; } = 20.0;
        public double PitchPressThresholdHz { get; set; } = 20.0; // Over målsone + denne verdien
        public int ConsecutiveWarningLimit { get; set; } = 3; // Antall advarsler før stopp
        
        /// <summary>
        /// Standard helsegrenser for trygg stemmetrening
        /// </summary>
        public static HealthProtectionThresholds Default()
        {
            return new HealthProtectionThresholds
            {
                MaxJitterPercent = 2.5,
                MaxShimmerPercent = 4.0,
                MaxAmplitudeSpikePercent = 20.0,
                PitchPressThresholdHz = 20.0,
                ConsecutiveWarningLimit = 3
            };
        }
    }
    
    /// <summary>
    /// Tilbakemeldingsregler for en parameter
    /// </summary>
    public class FeedbackRule
    {
        public string Parameter { get; set; } = ""; // pitch, resonance, stability, intonation
        public string CorrectKey { get; set; } = ""; // Localization key for correct
        public string AdjustKey { get; set; } = ""; // Localization key for adjust
        public string StopKey { get; set; } = ""; // Localization key for stop
    }
    
    /// <summary>
    /// Datastruktur som beskriver en øvelse med målparametere og toleranser
    /// </summary>
    public class ExerciseDefinition
    {
        public int ExerciseId { get; set; }
        public string Name { get; set; } = "";
        
        // Målparametere for pitch (Hz)
        public TargetRange TargetPitchRange { get; set; } = new(165, 220);
        
        // Målparametere for resonans (formanter i Hz)
        public TargetRange TargetF1Range { get; set; } = new(300, 1000);
        public TargetRange TargetF2Range { get; set; } = new(1800, 2500);
        public double TargetF3Min { get; set; } = 2700; // For avansert: F3 > 2700 Hz indikerer forward resonance
        
        // Stabilitet - akseptabel jitter prosent
        public double StabilityThresholdPercent { get; set; } = 2.0;
        
        // Belastningsgrenser
        public double StrainLimitShimmerPercent { get; set; } = 4.0;
        public double StrainLimitAmplitudeSpikePercent { get; set; } = 20.0;
        
        // Nivåbaserte skaleringsfaktorer
        public LevelScalingFactors NybegynnerFactors { get; set; } = LevelScalingFactors.ForNybegynner();
        public LevelScalingFactors MiddelsFactors { get; set; } = LevelScalingFactors.ForMiddels();
        public LevelScalingFactors AvansertFactors { get; set; } = LevelScalingFactors.ForAvansert();
        
        // Tilbakemeldingsregler
        public List<FeedbackRule> FeedbackRules { get; set; } = new();
        
        // Helsebeskyttelse
        public HealthProtectionThresholds HealthThresholds { get; set; } = HealthProtectionThresholds.Default();
        
        // Krever intonasjon (pitch-variasjon)
        public bool RequiresIntonation { get; set; }
        public TargetRange? IntonationRange { get; set; } // Prosentvis variasjon
        
        // Målkategori
        public GoalCategory GoalCategory { get; set; } = GoalCategory.Pitch;
        
        /// <summary>
        /// Hent skaleringsfaktorer basert på brukernivå
        /// </summary>
        public LevelScalingFactors GetScalingFactors(UserLevel level)
        {
            return level switch
            {
                UserLevel.Nybegynner => NybegynnerFactors,
                UserLevel.Middels => MiddelsFactors,
                UserLevel.Avansert => AvansertFactors,
                _ => MiddelsFactors
            };
        }
        
        /// <summary>
        /// Beregn effektiv pitch-toleranse med skaleringsfaktorer
        /// </summary>
        public double GetEffectivePitchTolerance(UserLevel level)
        {
            var baseTolerance = (TargetPitchRange.Max - TargetPitchRange.Min) / 2;
            var factors = GetScalingFactors(level);
            return baseTolerance * factors.PitchToleranceMultiplier;
        }
        
        /// <summary>
        /// Beregn effektiv resonans-toleranse med skaleringsfaktorer
        /// </summary>
        public double GetEffectiveResonanceToleranceF2(UserLevel level)
        {
            var baseTolerance = (TargetF2Range.Max - TargetF2Range.Min) / 2;
            var factors = GetScalingFactors(level);
            return baseTolerance * factors.ResonanceToleranceMultiplier;
        }
        
        /// <summary>
        /// Beregn effektiv stabilitetsgrense med skaleringsfaktorer
        /// </summary>
        public double GetEffectiveStabilityThreshold(UserLevel level)
        {
            var factors = GetScalingFactors(level);
            return StabilityThresholdPercent * factors.StabilityThresholdMultiplier;
        }
        
        /// <summary>
        /// Opprett ExerciseDefinition fra Exercise-objekt
        /// </summary>
        public static ExerciseDefinition FromExercise(Exercise exercise)
        {
            var definition = new ExerciseDefinition
            {
                ExerciseId = exercise.ExerciseId,
                Name = exercise.Name,
                TargetPitchRange = new TargetRange(exercise.TargetPitchMin, exercise.TargetPitchMax),
                GoalCategory = exercise.Goal,
                RequiresIntonation = exercise.Goal == GoalCategory.Intonation || exercise.Goal == GoalCategory.Combined
            };
            
            // Tilpass resonansområder basert på målkategori
            switch (exercise.Goal)
            {
                case GoalCategory.Resonance:
                    definition.TargetF1Range = new TargetRange(400, 800);
                    definition.TargetF2Range = new TargetRange(1800, 2600); // Forward resonance
                    break;
                case GoalCategory.Pitch:
                    definition.TargetF1Range = new TargetRange(300, 700);
                    definition.TargetF2Range = new TargetRange(1200, 1800);
                    break;
                case GoalCategory.Combined:
                    definition.TargetF1Range = new TargetRange(350, 750);
                    definition.TargetF2Range = new TargetRange(1500, 2200);
                    break;
                default:
                    definition.TargetF1Range = new TargetRange(300, 800);
                    definition.TargetF2Range = new TargetRange(1400, 2200);
                    break;
            }
            
            return definition;
        }
    }
}
