<Window x:Class="FemVoiceStudio.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:FemVoiceStudio.Converters"
        mc:Ignorable="d"
        Title="{loc:Loc Settings_Title}"
        Height="500" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundSecondaryBrush}">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="{loc:Loc Settings_Title}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>
        
        <!-- Content -->
        <StackPanel Grid.Row="1">
            <!-- Language Setting -->
            <Border Background="{DynamicResource BackgroundCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Settings_Language}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc Settings_SelectLanguage}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <ComboBox x:Name="LanguageComboBox" Width="200" HorizontalAlignment="Left" 
                              FontSize="14" SelectionChanged="OnLanguageSelectionChanged">
                        <ComboBoxItem Content="Norsk" Tag="nb-NO"/>
                        <ComboBoxItem Content="English" Tag="en-US"/>
                        <ComboBoxItem Content="Svenska" Tag="sv-SE"/>
                        <ComboBoxItem Content="Dansk" Tag="da-DK"/>
                        <ComboBoxItem Content="Suomi" Tag="fi-FI"/>
                        <ComboBoxItem Content="Deutsch" Tag="de-DE"/>
                        <ComboBoxItem Content="Français" Tag="fr-FR"/>
                        <ComboBoxItem Content="Español" Tag="es-ES"/>
                        <ComboBoxItem Content="Português" Tag="pt-BR"/>
                        <ComboBoxItem Content="Italiano" Tag="it-IT"/>
                        <ComboBoxItem Content="Hrvatski" Tag="hr-HR"/>
                    </ComboBox>
                </StackPanel>
            </Border>
            
            <!-- Theme Setting -->
            <Border Background="{DynamicResource BackgroundCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Settings_Theme}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc Settings_ThemeDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="ThemeSystemRadio" Content="{loc:Loc Settings_ThemeSystem}" GroupName="Theme" 
                                     FontSize="14" Margin="0,0,20,0" Checked="OnThemeChanged" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <RadioButton x:Name="ThemeLightRadio" Content="{loc:Loc Settings_ThemeLight}" GroupName="Theme" 
                                     FontSize="14" Margin="0,0,20,0" Checked="OnThemeChanged" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <RadioButton x:Name="ThemeDarkRadio" Content="{loc:Loc Settings_ThemeDark}" GroupName="Theme" 
                                     FontSize="14" Checked="OnThemeChanged" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Hear Own Voice Setting -->
            <Border Background="{DynamicResource BackgroundCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Settings_AudioSettings}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <CheckBox x:Name="HearOwnVoiceCheckBox" Content="{loc:Loc Settings_HearOwnVoice}" 
                              FontSize="14" Margin="0,0,0,8" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc Settings_HearOwnVoiceDesc}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <Button Content="{loc:Loc MicCalibration_Open}"
                            Click="OnOpenMicrophoneCalibration"
                            HorizontalAlignment="Left"
                            Padding="16,9"
                            Background="{DynamicResource AccentPrimaryBrush}"
                            Foreground="{DynamicResource TextOnAccentBrush}"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource BackgroundCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Settings_VoiceGoalTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc Settings_VoiceGoalDesc}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                    <TextBlock Text="{loc:Loc Settings_VoiceGoalFocus}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <ComboBox x:Name="VoiceGoalFocusComboBox" Width="230" HorizontalAlignment="Left" FontSize="14" Margin="0,0,0,12">
                        <ComboBoxItem Content="{loc:Loc VoiceGoalFocus_Balanced}" Tag="balanced"/>
                        <ComboBoxItem Content="{loc:Loc VoiceGoalFocus_Resonance}" Tag="resonance"/>
                        <ComboBoxItem Content="{loc:Loc VoiceGoalFocus_Intonation}" Tag="intonation"/>
                        <ComboBoxItem Content="{loc:Loc VoiceGoalFocus_Breathing}" Tag="breathing"/>
                        <ComboBoxItem Content="{loc:Loc VoiceGoalFocus_PitchComfort}" Tag="pitch"/>
                    </ComboBox>

                    <TextBlock Text="{loc:Loc Settings_VoiceGoalStyle}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <ComboBox x:Name="VoiceGoalStyleComboBox" Width="230" HorizontalAlignment="Left" FontSize="14">
                        <ComboBoxItem Content="{loc:Loc VoiceGoalStyle_SoftFeminine}" Tag="soft_feminine"/>
                        <ComboBoxItem Content="{loc:Loc VoiceGoalStyle_BrightNeutral}" Tag="bright_neutral"/>
                        <ComboBoxItem Content="{loc:Loc VoiceGoalStyle_Androgynous}" Tag="androgynous"/>
                        <ComboBoxItem Content="{loc:Loc VoiceGoalStyle_Custom}" Tag="custom"/>
                    </ComboBox>
                </StackPanel>
            </Border>
            
            <Border Background="{DynamicResource BackgroundCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Settings_Database}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc Settings_DatabaseDesc}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                    <Button Content="{loc:Loc UI_ClearDatabase}" 
                            Click="OnResetDatabase"
                            Background="{DynamicResource ErrorBrush}"
                            Foreground="{DynamicResource TextOnAccentBrush}"
                            Padding="16,10"
                            FontSize="14"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="6" 
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="{loc:Loc Settings_CreateBackup}"
                                Click="OnCreateBackup"
                                Background="{DynamicResource AccentPrimaryBrush}"
                                Foreground="{DynamicResource TextOnAccentBrush}"
                                Padding="16,10"
                                FontSize="14"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Settings_RestoreBackup}"
                                Click="OnRestoreBackup"
                                Background="{DynamicResource BackgroundSecondaryBrush}"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                Padding="16,10"
                                FontSize="14"
                                Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource BackgroundCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Settings_Accessibility_Title}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc Settings_Accessibility_Desc}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                    <CheckBox x:Name="StressSensitiveModeCheckBox" Content="{loc:Loc Settings_Accessibility_StressSensitive}"
                              FontSize="14" Margin="0,0,0,4" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc Settings_Accessibility_StressSensitiveDesc}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                    <CheckBox x:Name="ReducedVisualFeedbackCheckBox" Content="{loc:Loc Settings_Accessibility_ReducedVisual}"
                              FontSize="14" Margin="0,0,0,4" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc Settings_Accessibility_ReducedVisualDesc}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                    <TextBlock Text="{loc:Loc Settings_Accessibility_TrainingFrequency}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <ComboBox x:Name="TrainingFrequencyComboBox" Width="230" HorizontalAlignment="Left" FontSize="14">
                        <ComboBoxItem Content="{loc:Loc Settings_Accessibility_Frequency2}" Tag="2"/>
                        <ComboBoxItem Content="{loc:Loc Settings_Accessibility_Frequency3}" Tag="3"/>
                        <ComboBoxItem Content="{loc:Loc Settings_Accessibility_Frequency4}" Tag="4"/>
                        <ComboBoxItem Content="{loc:Loc Settings_Accessibility_Frequency5}" Tag="5"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource BackgroundCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Settings_ClinicalDisclaimerTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc Settings_ClinicalDisclaimerBody}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource BackgroundCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Privacy_Title}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc Privacy_LocalStorage}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{loc:Loc Privacy_DiagnosticsConsent}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{loc:Loc Privacy_ResearchWarning}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{loc:Loc Privacy_ProfessionalNotesWarning}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </StackPanel>
        
        <!-- Close button -->
        <Button Grid.Row="2" Content="{loc:Loc Settings_Close}" Click="OnClose" 
                HorizontalAlignment="Right"
                Padding="20,10"
                Background="#F44336"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                FontWeight="SemiBold"
                Margin="0,10,0,0">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#F44336" 
                                        CornerRadius="4" 
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#EF5350"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
        </Grid>
    </ScrollViewer>
</Window>
