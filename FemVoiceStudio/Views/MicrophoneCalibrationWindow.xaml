<Window x:Class="FemVoiceStudio.Views.MicrophoneCalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:FemVoiceStudio.Converters"
        Title="{loc:Loc MicCalibration_Title}"
        Height="460" Width="560"
        WindowStartupLocation="CenterOwner"
        MinHeight="420" MinWidth="520"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundSecondaryBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{loc:Loc MicCalibration_Title}" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="{loc:Loc MicCalibration_Intro}" Margin="0,8,0,0"
                       TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource BackgroundCardBrush}" CornerRadius="8" Padding="16">
            <StackPanel>
                <TextBlock x:Name="DeviceText" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                <TextBlock x:Name="InstructionText" Text="{loc:Loc MicCalibration_Ready}"
                           TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,16"/>
                <ProgressBar x:Name="Progress" Height="10" Minimum="0" Maximum="100" Value="0"/>
                <TextBlock x:Name="LevelText"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,10,0,0"/>
                <ScrollViewer Margin="0,16,0,0"
                              VerticalScrollBarVisibility="Auto"
                              MaxHeight="120">
                    <TextBlock x:Name="ResultText" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="StartButton" Content="{loc:Loc MicCalibration_Start}"
                    Click="OnStartCalibration"
                    Padding="18,10" Margin="0,0,8,0"
                    Background="{DynamicResource AccentPrimaryBrush}"
                    Foreground="{DynamicResource TextOnAccentBrush}"
                    BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="NextButton" Content="{loc:Loc MicCalibration_Next}"
                    Click="OnNextCalibrationStep"
                    Padding="18,10" Margin="0,0,8,0"
                    IsEnabled="False"
                    Background="{DynamicResource BackgroundTertiaryBrush}"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderThickness="0" Cursor="Hand"/>
            <Button Content="{loc:Loc Settings_Close}" Click="OnClose"
                    Padding="18,10"
                    Background="{DynamicResource BackgroundTertiaryBrush}"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
