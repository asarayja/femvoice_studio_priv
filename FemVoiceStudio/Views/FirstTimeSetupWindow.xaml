<Window x:Class="FemVoiceStudio.Views.FirstTimeSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:FemVoiceStudio.Converters"
        mc:Ignorable="d"
        Title="{loc:Loc FirstSetup_Title}"
        Height="620" Width="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundPrimaryBrush}">
    
    <Window.Resources>
        <!-- ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource BackgroundPrimaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        
        <!-- ComboBoxItem Style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource BackgroundPrimaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        
        <!-- RadioButton Style -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        
        <!-- ScrollViewer Style -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        
        <!-- TextBlock Styles -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
    </Window.Resources>
    
    <Border CornerRadius="0" Background="{DynamicResource BackgroundPrimaryBrush}" 
            BorderBrush="{DynamicResource AccentPrimaryBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource AccentBrush}" CornerRadius="0" Padding="20">
                <StackPanel>
                    <TextBlock Text="FemVoice Studio" FontSize="28" FontWeight="Bold" 
                               Foreground="{DynamicResource TextOnAccentBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="WelcomeText" Text="{loc:Loc FirstSetup_Welcome}" 
                               FontSize="14" Foreground="{DynamicResource TextOnAccentBrush}" 
                               HorizontalAlignment="Center" Margin="0,8,0,0" Opacity="0.9"/>
                </StackPanel>
            </Border>
            
            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30">
                <StackPanel>
                    <!-- Language Section -->
                    <Border Background="{DynamicResource BackgroundCardBrush}" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock x:Name="LanguageLabel" Text="{loc:Loc FirstSetup_SelectLanguage}" FontSize="18" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                            <TextBlock x:Name="LanguageDesc" Text="{loc:Loc FirstSetup_SelectLanguageDescription}" 
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" 
                                       TextWrapping="Wrap" Margin="0,0,0,15"/>
                            
                            <ComboBox x:Name="LanguageComboBox" FontSize="14" Padding="10,8" 
                                      SelectionChanged="OnLanguageSelectionChanged">
                                <ComboBoxItem Content="Norsk" Tag="nb"/>
                                <ComboBoxItem Content="English" Tag="en"/>
                                <ComboBoxItem Content="Svenska" Tag="sv"/>
                                <ComboBoxItem Content="Dansk" Tag="da"/>
                                <ComboBoxItem Content="Suomi" Tag="fi"/>
                                <ComboBoxItem Content="Deutsch" Tag="de"/>
                                <ComboBoxItem Content="Français" Tag="fr"/>
                                <ComboBoxItem Content="Español" Tag="es"/>
                                <ComboBoxItem Content="Português" Tag="pt"/>
                                <ComboBoxItem Content="Italiano" Tag="it"/>
                                <ComboBoxItem Content="Hrvatski" Tag="hr"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                    
                    <!-- Theme Section -->
                    <Border Background="{DynamicResource BackgroundCardBrush}" CornerRadius="10" Padding="20">
                        <StackPanel>
                            <TextBlock x:Name="ThemeLabel" Text="{loc:Loc FirstSetup_SelectTheme}" FontSize="18" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                            <TextBlock x:Name="ThemeDesc" Text="{loc:Loc FirstSetup_SelectThemeDescription}" 
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" 
                                       TextWrapping="Wrap" Margin="0,0,0,15"/>
                            
                            <StackPanel x:Name="ThemeOptions">
                                <RadioButton x:Name="ThemeSystem" GroupName="Theme" IsChecked="True" 
                                             Margin="0,0,0,12" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="32" Height="32" CornerRadius="4" Margin="0,0,12,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#FFFFFF" Offset="0"/>
                                                    <GradientStop Color="#1a1a1a" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Loc FirstSetup_SystemDefault}" FontSize="14" FontWeight="SemiBold" 
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{loc:Loc FirstSetup_SystemDefaultDescription}" FontSize="11" 
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton x:Name="ThemeLight" GroupName="Theme" 
                                             Margin="0,0,0,12" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="32" Height="32" CornerRadius="4" Background="#FAFAFA" 
                                                BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,12,0">
                                            <TextBlock Text="☀" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Loc FirstSetup_LightMode}" FontSize="14" FontWeight="SemiBold" 
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{loc:Loc FirstSetup_LightModeDescription}" FontSize="11" 
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton x:Name="ThemeDark" GroupName="Theme" 
                                             Margin="0,0,0,0" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="32" Height="32" CornerRadius="4" Background="#1E1E1E" 
                                                BorderBrush="#3D3D3D" BorderThickness="1" Margin="0,0,12,0">
                                            <TextBlock Text="🌙" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Loc FirstSetup_DarkMode}" FontSize="14" FontWeight="SemiBold" 
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{loc:Loc FirstSetup_DarkModeDescription}" FontSize="11" 
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Footer -->
            <Border Grid.Row="2" Background="{DynamicResource BackgroundSecondaryBrush}" 
                    CornerRadius="0" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button x:Name="SkipButton" Content="{loc:Loc FirstSetup_Skip}" 
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Padding="20,12"
                            FontSize="14"
                            Background="Transparent"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="OnSkipClick"/>
                    
                    <Button x:Name="ContinueButton" Content="{loc:Loc FirstSetup_Continue}" 
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Padding="30,12"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="{DynamicResource TextOnAccentBrush}"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="OnContinueClick">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
