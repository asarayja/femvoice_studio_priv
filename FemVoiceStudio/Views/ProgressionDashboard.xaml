<UserControl x:Class="FemVoiceStudio.Views.ProgressionDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:FemVoiceStudio.ViewModels"
             xmlns:converters="clr-namespace:FemVoiceStudio.Converters"
             xmlns:loc="clr-namespace:FemVoiceStudio.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="500">
    
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:LevelToColorConverter x:Key="LevelToColor"/>
        <converters:DirectionToArrowConverter x:Key="DirectionToArrow"/>
        <converters:ScoreToColorConverter x:Key="ScoreToColor"/>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- LEVEL INDICATOR SECTION -->
            <Border Grid.Row="0" 
                    Background="{DynamicResource BackgroundCardBrush}" 
                    CornerRadius="12" 
                    Padding="20"
                    Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.15" Direction="270"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Level Badge -->
                    <Border Grid.Column="0" 
                            Width="80" Height="80" 
                            CornerRadius="40"
                            Background="{Binding CurrentLevel, Converter={StaticResource LevelToColor}}"
                            Margin="0,0,16,0">
                        <TextBlock Text="{Binding LevelEmoji}" 
                                   FontSize="36" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- Level Info -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding LevelName}" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding LevelDescription}" 
                                   FontSize="13" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,4,0,0"/>
                        
                        <!-- Progress to next level -->
                        <Grid Margin="0,12,0,0" Height="8">
                            <Border Background="{DynamicResource BackgroundSecondaryBrush}" 
                                    CornerRadius="4"/>
                            <Border Background="{DynamicResource AccentPrimaryBrush}" 
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"
                                    Width="{Binding ProgressBarWidth}"/>
                        </Grid>
                        <TextBlock Text="{Binding ProgressText}" 
                                   FontSize="11" 
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                    
                    <!-- FemVoiceScore Circle -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Grid Width="70" Height="70">
                            <Ellipse Stroke="{DynamicResource BackgroundSecondaryBrush}" StrokeThickness="6"/>
                            <Ellipse Stroke="{Binding ScoreColor}" 
                                     StrokeThickness="6"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform Angle="-90"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <TextBlock Text="{Binding FemVoiceScore, StringFormat={}{0:F0}}" 
                                       FontSize="22" 
                                       FontWeight="Bold" 
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="{loc:Loc Dashboard_Score}" 
                                   FontSize="11" 
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- PARAMETER GRAPH SECTION -->
            <Border Grid.Row="1" 
                    Background="{DynamicResource BackgroundCardBrush}" 
                    CornerRadius="12" 
                    Padding="20"
                    Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.15" Direction="270"/>
                </Border.Effect>
                
                <StackPanel>
                    <TextBlock Text="{loc:Loc Dashboard_Parameters}" 
                               FontSize="16" 
                               FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,16"/>
                    
                    <!-- Resonance Row -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="{loc:Loc Dashboard_Resonance}" 
                                   VerticalAlignment="Center" 
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        
                        <Grid Grid.Column="1" Height="24">
                            <Border Background="{DynamicResource BackgroundSecondaryBrush}" CornerRadius="4"/>
                            <Border Background="{DynamicResource AccentPrimaryBrush}" 
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"
                                    Width="{Binding ResonanceBarWidth}"/>
                        </Grid>
                        
                        <TextBlock Grid.Column="2" 
                                   Text="{Binding ResonanceScore, StringFormat={}{0:F0}%}" 
                                   VerticalAlignment="Center" 
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        
                        <TextBlock Grid.Column="3" 
                                   Text="{Binding ResonanceDirection, Converter={StaticResource DirectionToArrow}}" 
                                   FontSize="18" 
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    
                    <!-- Pitch Row -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="{loc:Loc Dashboard_Pitch}" 
                                   VerticalAlignment="Center" 
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        
                        <Grid Grid.Column="1" Height="24">
                            <Border Background="{DynamicResource BackgroundSecondaryBrush}" CornerRadius="4"/>
                            <Border Background="{DynamicResource WarningBrush}" 
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"
                                    Width="{Binding PitchBarWidth}"/>
                        </Grid>
                        
                        <TextBlock Grid.Column="2" 
                                   Text="{Binding PitchScore, StringFormat={}{0:F0}%}" 
                                   VerticalAlignment="Center" 
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        
                        <TextBlock Grid.Column="3" 
                                   Text="{Binding PitchDirection, Converter={StaticResource DirectionToArrow}}" 
                                   FontSize="18" 
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    
                    <!-- Intonation Row -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="{loc:Loc Dashboard_Intonation}" 
                                   VerticalAlignment="Center" 
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        
                        <Grid Grid.Column="1" Height="24">
                            <Border Background="{DynamicResource BackgroundSecondaryBrush}" CornerRadius="4"/>
                            <Border Background="{DynamicResource InfoBrush}" 
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"
                                    Width="{Binding IntonationBarWidth}"/>
                        </Grid>
                        
                        <TextBlock Grid.Column="2" 
                                   Text="{Binding IntonationScore, StringFormat={}{0:F0}%}" 
                                   VerticalAlignment="Center" 
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        
                        <TextBlock Grid.Column="3" 
                                   Text="{Binding IntonationDirection, Converter={StaticResource DirectionToArrow}}" 
                                   FontSize="18" 
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    
                    <!-- Voice Health Row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="{loc:Loc Dashboard_VoiceHealth}" 
                                   VerticalAlignment="Center" 
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        
                        <Grid Grid.Column="1" Height="24">
                            <Border Background="{DynamicResource BackgroundSecondaryBrush}" CornerRadius="4"/>
                            <Border Background="{DynamicResource SuccessBrush}" 
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"
                                    Width="{Binding VoiceHealthBarWidth}"/>
                        </Grid>
                        
                        <TextBlock Grid.Column="2" 
                                   Text="{Binding VoiceHealthScore, StringFormat={}{0:F0}%}" 
                                   VerticalAlignment="Center" 
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        
                        <TextBlock Grid.Column="3"
                                   Text="{Binding VoiceHealthDirection, Converter={StaticResource DirectionToArrow}}"
                                   FontSize="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Sprint B: additional Voice Intelligence dimensions (0–100) -->
                    <!-- {loc}-TODO: dimension labels are English literals; add Strings.resx keys. -->

                    <!-- Comfort Row (Health) -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Comfort" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Grid Grid.Column="1" Height="24">
                            <Border Background="{DynamicResource BackgroundSecondaryBrush}" CornerRadius="4"/>
                            <Border Background="{DynamicResource SuccessBrush}" CornerRadius="4" HorizontalAlignment="Left" Width="{Binding ComfortBarWidth}"/>
                        </Grid>
                        <TextBlock Grid.Column="2" Text="{Binding ComfortScore, StringFormat={}{0:F0}%}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Grid>

                    <!-- Recovery Row (Health) -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Recovery" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Grid Grid.Column="1" Height="24">
                            <Border Background="{DynamicResource BackgroundSecondaryBrush}" CornerRadius="4"/>
                            <Border Background="{DynamicResource InfoBrush}" CornerRadius="4" HorizontalAlignment="Left" Width="{Binding RecoveryBarWidth}"/>
                        </Grid>
                        <TextBlock Grid.Column="2" Text="{Binding RecoveryScore, StringFormat={}{0:F0}%}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Grid>

                    <!-- Consistency Row -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Consistency" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Grid Grid.Column="1" Height="24">
                            <Border Background="{DynamicResource BackgroundSecondaryBrush}" CornerRadius="4"/>
                            <Border Background="{DynamicResource AccentPrimaryBrush}" CornerRadius="4" HorizontalAlignment="Left" Width="{Binding ConsistencyBarWidth}"/>
                        </Grid>
                        <TextBlock Grid.Column="2" Text="{Binding ConsistencyScore, StringFormat={}{0:F0}%}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Grid>

                    <!-- Vocal Weight Row -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Vocal Weight" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Grid Grid.Column="1" Height="24">
                            <Border Background="{DynamicResource BackgroundSecondaryBrush}" CornerRadius="4"/>
                            <Border Background="{DynamicResource WarningBrush}" CornerRadius="4" HorizontalAlignment="Left" Width="{Binding VocalWeightBarWidth}"/>
                        </Grid>
                        <TextBlock Grid.Column="2" Text="{Binding VocalWeightScore, StringFormat={}{0:F0}%}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Grid>

                    <!-- Voice Development (composite) -->
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Voice Development" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding CompositeVoiceScore, StringFormat={}{0:F0}%}" VerticalAlignment="Center" HorizontalAlignment="Right" FontWeight="Bold" Foreground="{DynamicResource AccentPrimaryBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- FOCUS AREA PANEL -->
            <Border Grid.Row="2" 
                    Background="{DynamicResource AccentLightBrush}" 
                    CornerRadius="12" 
                    Padding="20"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{loc:Loc Dashboard_TodaysFocus}" 
                                   FontSize="12" 
                                   Foreground="{DynamicResource AccentSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding FocusAreaTitle}" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding FocusAreaDescription}" 
                                   FontSize="13" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"/>
                        
                        <Button Content="{loc:Loc Dashboard_StartExercise}" 
                                Command="{Binding StartExerciseCommand}"
                                Background="{DynamicResource AccentPrimaryBrush}"
                                Foreground="{DynamicResource TextOnAccentBrush}"
                                Padding="16,10"
                                Margin="0,16,0,0"
                                FontWeight="SemiBold"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="8" 
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    
                    <Border Grid.Column="1" 
                            Width="60" Height="60" 
                            CornerRadius="30"
                            Background="{DynamicResource AccentPrimaryBrush}"
                            VerticalAlignment="Top"
                            Margin="16,0,0,0">
                        <TextBlock Text="{Binding FocusAreaIcon}" 
                                   FontSize="28" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
            
            <!-- QUICKEST IMPROVEMENT HIGHLIGHT -->
            <Border Grid.Row="3" 
                    Background="{DynamicResource BackgroundCardBrush}" 
                    CornerRadius="12" 
                    Padding="20"
                    Margin="0,0,0,16"
                    Visibility="{Binding ShowImprovementHighlight, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal">
                    <Border Width="48" Height="48" 
                            CornerRadius="24" 
                            Background="{DynamicResource SuccessBrush}"
                            Margin="0,0,16,0">
                        <TextBlock Text="📈" 
                                   FontSize="22" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{loc:Loc Dashboard_QuickestImprovement}" 
                                   FontSize="14" 
                                   FontWeight="SemiBold" 
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock FontSize="13" 
                                   Foreground="{DynamicResource TextSecondaryBrush}">
                            <Run Text="{Binding MostImprovedParameter}"/>
                            <Run Text="{loc:Loc Dashboard_ImprovedBy}"/>
                            <Run Text="{Binding ImprovementAmount, StringFormat={}{0:F1}}"/>
                            <Run Text="{loc:Loc Dashboard_PointsThisWeek}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- FEMVOICE SCORE HISTORY CHART -->
            <Border Grid.Row="4" 
                    Background="{DynamicResource BackgroundCardBrush}" 
                    CornerRadius="12" 
                    Padding="20"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Dashboard_ScoreHistory}" 
                               FontSize="16" 
                               FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,16"/>
                    
                    <!-- Simple bar chart representation -->
                    <ItemsControl ItemsSource="{Binding ScoreHistory}" Height="120">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="1,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Border Grid.Row="0" 
                                            VerticalAlignment="Bottom"
                                            CornerRadius="2,2,0,0"
                                            Background="{Binding ScoreColor}"
                                            Height="{Binding BarHeight}"/>
                                    
                                    <TextBlock Grid.Row="1" 
                                               Text="{Binding DayLabel}" 
                                               FontSize="8" 
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <TextBlock Text="{loc:Loc Dashboard_NotEnoughData}" 
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Visibility="{Binding ShowNoDataMessage, Converter={StaticResource BoolToVisibility}}"
                               Margin="0,20,0,20"/>
                </StackPanel>
            </Border>
            
            <!-- WEEKLY SUMMARY -->
            <Border Grid.Row="5" 
                    Background="{DynamicResource BackgroundCardBrush}" 
                    CornerRadius="12" 
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.15" Direction="270"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Sessions This Week -->
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding SessionsThisWeek}" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource AccentPrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{loc:Loc Dashboard_Sessions}" 
                                   FontSize="12" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Minutes This Week -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding MinutesThisWeek}" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource WarningBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{loc:Loc Dashboard_Minutes}" 
                                   FontSize="12" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Average Score -->
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding WeeklyAverageScore, StringFormat={}{0:F0}}" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource SuccessBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{loc:Loc Dashboard_Average}" 
                                   FontSize="12" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
