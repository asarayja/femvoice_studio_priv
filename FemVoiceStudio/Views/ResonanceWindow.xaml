<Window x:Class="FemVoiceStudio.Views.ResonanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:loc="clr-namespace:FemVoiceStudio.Converters"
        Title="{loc:Loc ResonanceWindow_Title}"
        Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundSecondaryBrush}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{loc:Loc ResonanceWindow_Title}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="{loc:Loc ResonanceWindow_Subtitle}" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>
        
        <!-- Main Charts -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- F1/F2 Scatter Plot -->
            <Border Grid.Column="0" Background="{DynamicResource BackgroundCardBrush}" CornerRadius="8" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="{loc:Loc ResonanceWindow_F1F2Position}" FontSize="16" FontWeight="SemiBold" 
                               Margin="16,12,16,8" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    
                    <oxy:PlotView Grid.Row="1" x:Name="F1F2PlotView" Margin="8"/>
                </Grid>
            </Border>
            
            <!-- Formant Timeline -->
            <Border Grid.Column="1" Background="{DynamicResource BackgroundCardBrush}" CornerRadius="8" Margin="8,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="{loc:Loc ResonanceWindow_FormantTimeline}" FontSize="16" FontWeight="SemiBold" 
                               Margin="16,12,16,8" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    
                    <oxy:PlotView Grid.Row="1" x:Name="TimelinePlotView" Margin="8"/>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Current Values Panel -->
        <Border Grid.Row="2" Background="{DynamicResource BackgroundCardBrush}" CornerRadius="8" Padding="16" Margin="0,16,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Resonance Score -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="{loc:Loc ResonanceWindow_ResonanceScore}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="ResonanceScoreText" Text="--" FontSize="28" FontWeight="Bold" 
                               Foreground="{DynamicResource AccentPrimaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <!-- F1 Value -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="F1 (Hz)" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="F1ValueText" Text="--" FontSize="24" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <!-- F2 Value -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="F2 (Hz)" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="F2ValueText" Text="--" FontSize="24" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <!-- F3 Value -->
                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="F3 (Hz)" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="F3ValueText" Text="--" FontSize="24" FontWeight="SemiBold" 
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <!-- Category -->
                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                    <TextBlock Text="{loc:Loc ResonanceWindow_Category}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="CategoryText" Text="--" FontSize="18" FontWeight="SemiBold" 
                               Foreground="{DynamicResource WarningBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Controls — temastiler (PrimaryButtonStyle/DangerButtonStyle/SecondaryButtonStyle
             finnes i både LightTheme og DarkTheme; DynamicResource så temabytte virker).
             Tidligere: rå Background/Foreground-attributter uten stil (= umalte knapper),
             og StopButton refererte DangerBrush som ikke finnes i temaene. -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="StartButton" Content="{loc:Loc ResonanceWindow_StartAnalysis}"
                    Click="StartButton_Click"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    Padding="24,12" Margin="0,0,16,0"/>

            <Button x:Name="StopButton" Content="{loc:Loc Exercise_Stop}"
                    Click="StopButton_Click"
                    Style="{DynamicResource DangerButtonStyle}"
                    Padding="24,12" Margin="0,0,16,0"
                    IsEnabled="False"/>

            <Button x:Name="ResetButton" Content="{loc:Loc UI_Reset}"
                    Click="ResetButton_Click"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Padding="24,12"/>
        </StackPanel>
    </Grid>
</Window>
