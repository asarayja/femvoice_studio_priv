<Window x:Class="FemVoiceStudio.Views.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:FemVoiceStudio.Converters"
        xmlns:loc="clr-namespace:FemVoiceStudio.Converters"
        mc:Ignorable="d"
        Title="{loc:Loc Statistics_Title}"
        Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundSecondaryBrush}">
    
    <Window.Resources>
        <converters:ScoreToColorConverter x:Key="ScoreToColor"/>
        <converters:DifficultyToColorConverter x:Key="DifficultyToColor"/>
        
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundCardBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Header -->
            <TextBlock Text="{loc:Loc Statistics_Title}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,24"/>
            
            <!-- Top Stats -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Total Sessions -->
                <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="32" HorizontalAlignment="Center" Foreground="{DynamicResource InfoBrush}"/>
                        <TextBlock x:Name="TotalSessionsText" Text="0" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{loc:Loc Statistics_TotalSessions}" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <!-- Current Streak -->
                <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="8,0,8,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE7BC;" FontFamily="Segoe MDL2 Assets" FontSize="32" HorizontalAlignment="Center" Foreground="{DynamicResource WarningBrush}"/>
                        <TextBlock x:Name="StreakText" Text="0" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource WarningBrush}"/>
                        <TextBlock Text="{loc:Loc Statistics_CurrentStreak}" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <!-- Average Score -->
                <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="8,0,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE735;" FontFamily="Segoe MDL2 Assets" FontSize="32" HorizontalAlignment="Center" Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock x:Name="AvgScoreText" Text="0%" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock Text="{loc:Loc Statistics_AverageScore}" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- Pitch Stats -->
            <Border Style="{StaticResource StatCard}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Statistics_PitchStatistics}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Statistics_AveragePitch}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="AvgPitchText" Text="0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text=" Hz" FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{loc:Loc Statistics_DetailedScore}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="DetailedScoreText" Text="0%" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Current Level -->
            <Border Style="{StaticResource StatCard}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Statistics_CurrentLevel}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="LevelText" Text="{Binding CurrentLevel}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <ProgressBar x:Name="LevelProgress" Maximum="100" Height="10" Margin="0,12,0,8"
                                         Background="{DynamicResource BackgroundTertiaryBrush}" Foreground="{DynamicResource AccentPrimaryBrush}"/>
                            <TextBlock x:Name="LevelProgressText" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Recent Sessions -->
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Statistics_RecentSessions}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    
                    <ItemsControl x:Name="RecentSessionsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="0,0,0,1" Padding="0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding DateText}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Difficulty}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        
                                        <TextBlock Grid.Column="1" Text="{Binding DurationText}" FontSize="14" 
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                        
                                        <Border Grid.Column="2" CornerRadius="4" Padding="8,4" VerticalAlignment="Center"
                                                Background="{Binding Score, Converter={StaticResource ScoreToColor}}">
                                            <TextBlock Text="{Binding ScoreText}" Foreground="{DynamicResource TextOnAccentBrush}" FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
