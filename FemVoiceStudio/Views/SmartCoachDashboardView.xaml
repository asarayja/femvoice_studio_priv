<UserControl x:Class="FemVoiceStudio.Views.SmartCoachDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:FemVoiceStudio.ViewModels"
             xmlns:converters="clr-namespace:FemVoiceStudio.Converters"
             xmlns:loc="clr-namespace:FemVoiceStudio.Converters"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="400">
    
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:BoolToWarningColorConverter x:Key="BoolToWarningColor"/>
    </UserControl.Resources>
    
    <Border Background="{DynamicResource BackgroundCardBrush}" 
            CornerRadius="12" 
            Padding="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.15" Direction="270"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <Border Background="{DynamicResource AccentPrimaryBrush}" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                    <TextBlock Text="&#xE7BC;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource TextOnAccentBrush}"/>
                </Border>
                <TextBlock Text="{loc:Loc SmartCoach_Title}" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <Ellipse Width="8" Height="8" Margin="10,0,0,0" 
                         Fill="{Binding HasHealthWarning, Converter={StaticResource BoolToWarningColor}}"
                         VerticalAlignment="Center"
                         Visibility="{Binding HasHealthWarning, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
            
            <!-- Main Content -->
            <Grid Grid.Row="1">
                <!-- Loading State -->
                <TextBlock Text="{loc:Loc SmartCoach_Loading}" 
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
                
                <!-- No Data State -->
                <StackPanel Visibility="{Binding HasData, Converter={StaticResource InverseBoolToVisibility}}"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Background="{DynamicResource AccentLightBrush}" CornerRadius="40" Width="64" Height="64" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="{DynamicResource AccentSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{loc:Loc SmartCoach_BuildingBaseline}" 
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,8,0,0"
                               MaxWidth="250"/>
                </StackPanel>
                
                <!-- Main Recommendation (when data exists) -->
                <StackPanel Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
                    <!-- focus Area Badge -->
                    <Border Background="{DynamicResource AccentLightBrush}" 
                            CornerRadius="4" 
                            Padding="8,4" 
                            HorizontalAlignment="Left"
                            Margin="0,0,0,8">
                        <TextBlock Text="{Binding TodayFocus}" 
                                   FontSize="12" 
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource AccentSecondaryBrush}"/>
                    </Border>
                    
                    <!-- Recommendation Text -->
                    <TextBlock Text="{Binding TodayRecommendation}" 
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="60"
                               LineHeight="20"/>
                    
                    <!-- Health Warning -->
                    <!-- Tilgjengelighet: Foreground bindes til den dynamiske
                         HealthWarningBrush (ErrorBrush→WarningBrush ved StressSensitiveMode)
                         i stedet for den hardkodede alarmfargen. HealthWarningText er
                         uberørt — helsevarselet formidles alltid. TargetNullValue gir en
                         trygg fallback når Application-ressurser mangler (design/test). -->
                    <Border Background="#33FF5555"
                            CornerRadius="6"
                            Padding="10,8"
                            Margin="0,10,0,0"
                            Visibility="{Binding HasHealthWarning, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠️" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding HealthWarningText}"
                                       FontSize="12"
                                       Foreground="{Binding HealthWarningBrush, TargetNullValue=#FFFF8888, FallbackValue=#FFFF8888}"
                                       TextWrapping="Wrap"
                                       MaxWidth="280"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
            
            <!-- Quick Stats Row -->
            <Grid Grid.Row="2" Margin="0,12,0,0" 
                  Visibility="{Binding HasData, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Streak (sekundær badge) -->
                <!-- Tilgjengelighet: skjules ved ReducedVisualFeedback for å redusere
                     antall samtidige sekundære signaler. Helse-/safety-info beholdes. -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center"
                            Visibility="{Binding ShowSecondaryBadges, Converter={StaticResource BoolToVisibility}}">
                    <Border Background="{DynamicResource WarningBrush}" CornerRadius="20" Width="40" Height="40" HorizontalAlignment="Center" Margin="0,0,0,6">
                        <TextBlock Text="&#xE7BC;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding CurrentStreak}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource WarningBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Loc SmartCoach_Days}"
                               FontSize="10"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Sessions This Week (sekundær badge) -->
                <!-- Tilgjengelighet: skjules ved ReducedVisualFeedback (se over). -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center"
                            Visibility="{Binding ShowSecondaryBadges, Converter={StaticResource BoolToVisibility}}">
                    <Border Background="{DynamicResource InfoBrush}" CornerRadius="20" Width="40" Height="40" HorizontalAlignment="Center" Margin="0,0,0,6">
                        <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding SessionsThisWeek}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource InfoBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Loc SmartCoach_Sessions}"
                               FontSize="10"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Health Score (beholdes alltid — helse-info) -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <Border Background="{DynamicResource SuccessBrush}" CornerRadius="20" Width="40" Height="40" HorizontalAlignment="Center" Margin="0,0,0,6">
                        <TextBlock Text="&#xE8E1;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding HealthScore, StringFormat={}{0:F0}%}" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource SuccessBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Loc SmartCoach_Health}" 
                               FontSize="10" 
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
