<Window x:Class="FemVoiceStudio.Views.ManualOverrideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        xmlns:models="clr-namespace:FemVoiceStudio.Models"
        xmlns:converters="clr-namespace:FemVoiceStudio.Converters"
        xmlns:loc="clr-namespace:FemVoiceStudio.Converters"
        mc:Ignorable="d"
        Title="{loc:Loc Override_Title}"
        Height="720" Width="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundSecondaryBrush}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Enum value sources for the selectors. -->
        <ObjectDataProvider x:Key="OverrideKinds"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:ManualOverrideKind"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider x:Key="ProfileTypes"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:ExerciseProfileType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider x:Key="StyleGoals"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:VoiceStyleGoal"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundCardBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,8,0,2"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Header -->
            <TextBlock Text="{loc:Loc Override_Title}"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,16"/>

            <!-- Request: what is being overridden -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Override_Kind}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Source={StaticResource OverrideKinds}}"
                              SelectedItem="{Binding SelectedKind, Mode=TwoWay}"
                              Style="{DynamicResource StandardComboBoxStyle}"/>

                    <TextBlock Text="{loc:Loc Dimension_Resonance}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Source={StaticResource ProfileTypes}}"
                              SelectedItem="{Binding BaselineProfileType, Mode=TwoWay}"
                              Style="{DynamicResource StandardComboBoxStyle}"/>

                    <TextBlock Text="{loc:Loc Override_Reason}" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding ReasonCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource StandardTextBoxStyle}"/>
                </StackPanel>
            </Border>

            <!-- Intended requirement values (the REQUEST — not the result) -->
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Dimension_VocalWeight}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Source={StaticResource StyleGoals}}"
                              SelectedItem="{Binding StyleGoal, Mode=TwoWay}"
                              Style="{DynamicResource StandardComboBoxStyle}"/>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="{loc:Loc Dimension_Resonance}" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding IntendedResonanceMin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource StandardTextBoxStyle}"/>
                            <TextBox Text="{Binding IntendedResonanceMax, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="{loc:Loc Dimension_Consistency}" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding IntendedStabilityThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Text="{Binding IntendedRequiredHoldSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Button Content="{loc:Loc Override_Apply}"
                            Command="{Binding ApplyCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Result: CLAMPED OUTCOME ONLY. Visible once an Apply has run. -->
            <Border Style="{StaticResource SectionCard}"
                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Report_Outcome}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>

                    <!-- Status indicators -->
                    <TextBlock Text="{loc:Loc Override_Clamped}"
                               Foreground="{DynamicResource WarningBrush}" FontWeight="SemiBold"
                               Visibility="{Binding WasClamped, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{loc:Loc Override_Blocked}"
                               Foreground="{DynamicResource ErrorBrush}" FontWeight="SemiBold"
                               Visibility="{Binding WasBlocked, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{loc:Loc Override_Logged}"
                               Foreground="{DynamicResource SuccessBrush}"
                               Visibility="{Binding WasLogged, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- The clamped (applied) requirement values — the only values shown. -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Loc Dimension_Resonance}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding AppliedResonanceMin, StringFormat=F2}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Loc Dimension_Resonance}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding AppliedResonanceMax, StringFormat=F2}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Loc Dimension_Consistency}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding AppliedStabilityThreshold, StringFormat=F2}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{loc:Loc Dimension_Consistency}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{Binding AppliedRequiredHoldSeconds, StringFormat=F1}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>

                    <!-- In-session outcome trail (append-only). -->
                    <TextBlock Text="{loc:Loc Override_Logged}"
                               Style="{StaticResource FieldLabel}" Margin="0,12,0,2"/>
                    <ItemsControl ItemsSource="{Binding OutcomeLog}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
