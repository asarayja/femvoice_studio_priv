<UserControl x:Class="FemVoiceStudio.Views.ClinicianDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:FemVoiceStudio.Converters"
             xmlns:converters="clr-namespace:FemVoiceStudio.Converters"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="820"
             x:Name="ClinicianDashboardRoot">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter      x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:ScoreToColorConverter          x:Key="ScoreToColor"/>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background"   Value="{DynamicResource BackgroundCardBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding"      Value="20"/>
            <Setter Property="Margin"       Value="0,0,0,14"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><!-- 0 header -->
                <RowDefinition Height="Auto"/><!-- 1 voice metrics -->
                <RowDefinition Height="Auto"/><!-- 2 recovery -->
                <RowDefinition Height="Auto"/><!-- 3 trends -->
                <RowDefinition Height="Auto"/><!-- 4 exercise effectiveness -->
                <RowDefinition Height="Auto"/><!-- 5 learning path -->
                <RowDefinition Height="Auto"/><!-- 6 goal progress -->
                <RowDefinition Height="Auto"/><!-- 7 insights -->
            </Grid.RowDefinitions>

            <!-- ── 0: HEADER ──────────────────────────────────────────────────── -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.12" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Loc Clinician_Title}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{loc:Loc Clinician_VoiceMetrics}"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center"
                                VerticalAlignment="Center" Margin="16,0,0,0">
                        <Border Width="72" Height="72" CornerRadius="36"
                                Background="{DynamicResource AccentLightBrush}">
                            <TextBlock Text="{Binding CompositeScore, StringFormat={}{0:F0}}"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentPrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{loc:Loc Dashboard_VoiceDevelopment}"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── 1: VOICE METRICS (7 dimensions, colored score values) ────────── -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Clinician_VoiceMetrics}" Style="{StaticResource SectionTitle}"/>

                    <!-- 7-dimension grid: label | score value (color-coded via ScoreToColor) -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="24"/>
                        </Grid.RowDefinitions>

                        <!-- Labels col 0 -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Loc Dimension_Resonance}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Loc Dimension_Comfort}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Loc Dimension_Consistency}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{loc:Loc Dimension_Recovery}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{loc:Loc Dimension_Intonation}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="{loc:Loc Dimension_VocalWeight}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="{loc:Loc Dimension_Pitch}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>

                        <!-- Values col 1 (color-coded) -->
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding ResonanceScore,    StringFormat={}{0:F0}/100}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding ResonanceScore,    Converter={StaticResource ScoreToColor}}"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding ComfortScore,      StringFormat={}{0:F0}/100}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding ComfortScore,      Converter={StaticResource ScoreToColor}}"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding ConsistencyScore,  StringFormat={}{0:F0}/100}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding ConsistencyScore,  Converter={StaticResource ScoreToColor}}"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{Binding RecoveryMetricScore, StringFormat={}{0:F0}/100}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding RecoveryMetricScore, Converter={StaticResource ScoreToColor}}"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="1"
                                   Text="{Binding IntonationScore,   StringFormat={}{0:F0}/100}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding IntonationScore,   Converter={StaticResource ScoreToColor}}"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="5" Grid.Column="1"
                                   Text="{Binding VocalWeightScore,  StringFormat={}{0:F0}/100}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding VocalWeightScore,  Converter={StaticResource ScoreToColor}}"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="6" Grid.Column="1"
                                   Text="{Binding PitchScore,        StringFormat={}{0:F0}/100}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding PitchScore,        Converter={StaticResource ScoreToColor}}"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── 2: RECOVERY STATUS ────────────────────────────────────────────── -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Clinician_RecoveryStatus}" Style="{StaticResource SectionTitle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="{Binding RecoveryStatus}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding RecoveryScore0to100, StringFormat={}{0:F0}/100}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding RecoveryRecommendation}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock FontSize="11"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       Margin="0,0,0,4">
                                <Run Text="Gjeld: "/>
                                <Run Text="{Binding RecoveryDebt, StringFormat={}{0:F0}/100}"/>
                            </TextBlock>
                            <TextBlock Text="Overtrening forutsagt"
                                       FontSize="12"
                                       Foreground="{DynamicResource ErrorBrush}"
                                       Visibility="{Binding OvertrainingPredicted, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── 3: DIMENSION TRENDS (slope per window) ─────────────────────────── -->
            <Border Grid.Row="3" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="{loc:Loc Clinician_ComfortTrend}" Style="{StaticResource SectionTitle}"/>
                        <ItemsControl ItemsSource="{Binding ComfortTrend}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Value, StringFormat={}{0:+0.00;-0.00;0.00}}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,10,0">
                        <TextBlock Text="{loc:Loc Clinician_ResonanceTrend}" Style="{StaticResource SectionTitle}"/>
                        <ItemsControl ItemsSource="{Binding ResonanceTrend}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Value, StringFormat={}{0:+0.00;-0.00;0.00}}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="10,0,0,0">
                        <TextBlock Text="{loc:Loc Clinician_ConsistencyTrend}" Style="{StaticResource SectionTitle}"/>
                        <ItemsControl ItemsSource="{Binding ConsistencyTrend}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Value, StringFormat={}{0:+0.00;-0.00;0.00}}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── 4: EXERCISE EFFECTIVENESS ─────────────────────────────────────── -->
            <Border Grid.Row="4" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Clinician_ExerciseEffectiveness}" Style="{StaticResource SectionTitle}"/>

                    <DataGrid ItemsSource="{Binding RankedExercises}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowBackground="Transparent"
                              AlternatingRowBackground="{DynamicResource BackgroundSecondaryBrush}"
                              BorderThickness="0"
                              Margin="0,0,0,10"
                              MaxHeight="180">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding ExerciseId}"
                                                Width="38" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Effektivitet"
                                                Binding="{Binding CompositeEffectiveness, StringFormat={}{0:F1}}"
                                                Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Resonansgevinst"
                                                Binding="{Binding ResonanceGain, StringFormat={}{0:+0.00;-0.00;0.00}}"
                                                Width="110" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Komfortgevinst"
                                                Binding="{Binding ComfortGain, StringFormat={}{0:+0.00;-0.00;0.00}}"
                                                Width="105" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Gjenkostn."
                                                Binding="{Binding RecoveryCost, StringFormat={}{0:F1}}"
                                                Width="78" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Suksess%"
                                                Binding="{Binding UserSuccessRate, StringFormat={}{0:F0}%}"
                                                Width="72" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Økter"
                                                Binding="{Binding SessionCount}"
                                                Width="50" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <ItemsControl ItemsSource="{Binding ExerciseConcerns}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock TextWrapping="Wrap" Margin="0,2"
                                           FontSize="11"
                                           Foreground="{DynamicResource WarningBrush}">
                                    <Run Text="{Binding ExerciseId, StringFormat=Øvelse {0}: }"/>
                                    <Run Text="{Binding Explanation}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ── 5: LEARNING PATH ──────────────────────────────────────────────── -->
            <Border Grid.Row="5" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="{loc:Loc Clinician_LearningPath}" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="{Binding LearningStageLabel}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentPrimaryBrush}"/>
                        <TextBlock Text="{Binding LearningStageExplanation}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,8"/>
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource TextTertiaryBrush}">
                            <Run Text="Sikkerhet: "/>
                            <Run Text="{Binding ConfidenceLabel}"/>
                            <Run Text=" ("/>
                            <Run Text="{Binding ConfidenceScore, StringFormat={}{0:F0}}"/>
                            <Run Text=")"/>
                        </TextBlock>
                        <TextBlock Text="Fokusområder:"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,10,0,4"/>
                        <ItemsControl ItemsSource="{Binding FocusAreas}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource AccentLightBrush}"
                                            CornerRadius="4" Padding="6,3" Margin="0,2">
                                        <TextBlock Text="{Binding}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource AccentPrimaryBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,10,0">
                        <TextBlock Text="Styrker:" Style="{StaticResource SectionTitle}"/>
                        <ItemsControl ItemsSource="{Binding Strengths}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Dimension}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Score, StringFormat={}{0:F0}}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SuccessBrush}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="10,0,0,0">
                        <TextBlock Text="Svakheter:" Style="{StaticResource SectionTitle}"/>
                        <ItemsControl ItemsSource="{Binding Weaknesses}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Dimension}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Score, StringFormat={}{0:F0}}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource WarningBrush}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── 6: GOAL PROGRESS ──────────────────────────────────────────────── -->
            <Border Grid.Row="6" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Målfremdrift" Style="{StaticResource SectionTitle}"/>
                    <DataGrid ItemsSource="{Binding GoalProgressItems}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowBackground="Transparent"
                              AlternatingRowBackground="{DynamicResource BackgroundSecondaryBrush}"
                              BorderThickness="0"
                              MaxHeight="160">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mål"
                                                Binding="{Binding GoalType}"
                                                Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Nåverdi"
                                                Binding="{Binding CurrentValue, StringFormat={}{0:F1}}"
                                                Width="75" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Mål"
                                                Binding="{Binding TargetValue, StringFormat={}{0:F1}}"
                                                Width="65" IsReadOnly="True"/>
                            <DataGridTextColumn Header="%"
                                                Binding="{Binding PercentComplete, StringFormat={}{0:F0}%}"
                                                Width="50" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- ── 7: LONGITUDINAL INSIGHTS ─────────────────────────────────────── -->
            <Border Grid.Row="7" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Longitudinale innsikter" Style="{StaticResource SectionTitle}"/>

                    <ItemsControl ItemsSource="{Binding Insights}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                                        CornerRadius="6" Padding="12,8" Margin="0,4">
                                    <TextBlock Text="{Binding}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="{loc:Loc Dashboard_NotEnoughData}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,16"
                               Visibility="{Binding HasEnoughData, Converter={StaticResource InverseBoolToVisibility}}"/>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>
