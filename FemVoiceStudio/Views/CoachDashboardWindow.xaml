<Window x:Class="FemVoiceStudio.Views.CoachDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:loc="clr-namespace:FemVoiceStudio.Converters"
        xmlns:views="clr-namespace:FemVoiceStudio.Views"
        mc:Ignorable="d"
        Title="{loc:Loc Coach_Title}"
        Height="680" Width="760"
        MinHeight="480" MinWidth="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundSecondaryBrush}">

    <!-- The window shell wraps the CoachDashboard UserControl so it can also be
         opened standalone via new CoachDashboardWindow().Show(). The UserControl
         manages its own DataContext and Refresh call on Loaded. -->
    <views:CoachDashboard/>

</Window>
