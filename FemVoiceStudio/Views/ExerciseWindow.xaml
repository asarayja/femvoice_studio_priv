<Window x:Class="FemVoiceStudio.Views.ExerciseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:FemVoiceStudio.Converters"
        xmlns:vm="clr-namespace:FemVoiceStudio.ViewModels"
        mc:Ignorable="d"
        Title="{loc:Loc Exercise_GuideWindowTitle}"
        Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundSecondaryBrush}">

    <Window.Resources>

        <!-- ── Converters (uendret) ───────────────────────────────────────────── -->
        <loc:BoolToVisibilityConverter          x:Key="BoolToVisibility"/>
        <loc:InverseBoolToVisibilityConverter   x:Key="InverseBoolToVisibility"/>
        <loc:ProgressToPercentConverter         x:Key="ProgressToPercent"/>
        <loc:SeverityToBrushConverter           x:Key="SeverityToBrush"/>

        <!-- ── Existing button and card styles (uendret) ─────────────────────── -->
        <Style x:Key="GoalBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>

        <Style x:Key="FrequencyBadge" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentPrimaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentSecondaryBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource BackgroundTertiaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource InfoBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BackButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           VerticalAlignment="Center" Margin="0,0,6,0"
                                           Foreground="{TemplateBinding Foreground}"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BackgroundHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BackgroundTertiaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExerciseCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundCardBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CategoryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BackgroundHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Live Feedback stiler (uendret) ─────────────────────────────────── -->
        <Style x:Key="IndicatorLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style x:Key="MetricBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource BackgroundTertiaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border CornerRadius="4" Background="{TemplateBinding Background}">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="4"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Guidance panel stiler (uendret) ────────────────────────────────── -->
        <Style x:Key="GuidanceCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundTertiaryBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <Style x:Key="GuidanceHeading" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="GuidanceBody" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!--
            FIX 2: GuidanceItemTemplate — HeadingKey and BodyKey both go through
            LocConverter. Raw RESX keys are never displayed in the UI.
        -->
        <DataTemplate x:Key="GuidanceItemTemplate" DataType="{x:Type vm:GuidanceItem}">
            <Border Style="{StaticResource GuidanceCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="{Binding IconGlyph}"
                                   FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource AccentPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <!-- HeadingKey → LocConverter resolves to localised heading text -->
                        <TextBlock Text="{Binding HeadingKey, Converter={loc:LocConverter}}"
                                   Style="{StaticResource GuidanceHeading}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- BodyKey → LocConverter resolves to localised body text -->
                    <TextBlock Text="{Binding BodyKey, Converter={loc:LocConverter}}"
                               Style="{StaticResource GuidanceBody}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid>

        <!-- ══ LIST VIEW (uendret) ════════════════════════════════════════════ -->
        <Grid x:Name="ListView" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="{loc:Loc Exercise_Title}" FontSize="28" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text=" – " FontSize="28"
                           Foreground="{DynamicResource AccentPrimaryBrush}"
                           VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                <TextBlock Text="{loc:Loc Exercise_Subtitle}" FontSize="28"
                           Foreground="{DynamicResource AccentPrimaryBrush}"
                           VerticalAlignment="Bottom" Margin="0,0,0,2"/>
            </StackPanel>

            <Border Grid.Row="1" Background="{DynamicResource BackgroundCardBrush}"
                    CornerRadius="12" Padding="16" Margin="0,0,0,16">
                <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="{loc:Loc Exercise_TodaysProgress}" FontSize="16"
                               FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock x:Name="MinutesText" Text="0" FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentPrimaryBrush}"/>
                        <TextBlock Text="{loc:Loc Exercise_MinutesTarget}" FontSize="24"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0"/>
                        <TextBlock x:Name="SessionsText" Text=" (0" FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Bottom" Margin="8,0,0,2"/>
                        <TextBlock Text="{loc:Loc Exercise_SessionsCount}" FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                        <TextBlock Text=")" FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="CatAll"        Content="{loc:Loc Exercise_All}"                Click="OnCategoryClick" Tag="0" Style="{StaticResource CategoryButton}"/>
                    <Button x:Name="CatPitch"      Content="{loc:Loc Exercise_CategoryPitch}"      Click="OnCategoryClick" Tag="1" Style="{StaticResource CategoryButton}"/>
                    <Button x:Name="CatResonance"  Content="{loc:Loc Exercise_CategoryResonance}"  Click="OnCategoryClick" Tag="2" Style="{StaticResource CategoryButton}"/>
                    <Button x:Name="CatIntonation" Content="{loc:Loc Exercise_CategoryIntonation}" Click="OnCategoryClick" Tag="3" Style="{StaticResource CategoryButton}"/>
                    <Button x:Name="CatBreathing"  Content="{loc:Loc Exercise_CategoryBreathing}"  Click="OnCategoryClick" Tag="4" Style="{StaticResource CategoryButton}"/>
                    <Button x:Name="CatPractice"   Content="{loc:Loc Exercise_CategoryPractice}"   Click="OnCategoryClick" Tag="5" Style="{StaticResource CategoryButton}"/>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ExerciseList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ExerciseCard}" Cursor="Hand"
                                    MouseLeftButtonUp="OnExerciseClick">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                            Background="{DynamicResource AccentPrimaryBrush}">
                                        <TextBlock Text="{Binding IconGlyph}"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="24"
                                                   Foreground="{DynamicResource TextOnAccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Border CornerRadius="8" Padding="6,2" Margin="0,0,8,0"
                                                    Background="{DynamicResource AccentLightBrush}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding GoalIconGlyph}"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="10"
                                                               Margin="0,0,4,0"
                                                               Foreground="{DynamicResource AccentPrimaryBrush}"/>

                                                    <TextBlock Text="{Binding Goal}" FontSize="10"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                </StackPanel>
                                            </Border>
                                            <TextBlock Text="{Binding DisplayDifficulty}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text=" • " FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding DurationMinutes}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{loc:Loc Exercise_Min}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Border Background="{DynamicResource AccentLightBrush}" CornerRadius="6" Padding="6,2">
                                                <TextBlock Text="{Binding FrequencyText}" FontSize="10"
                                                           Foreground="{DynamicResource AccentMutedBrush}"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="400" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <TextBlock HorizontalAlignment="Right">
                                            <Run Text="{Binding TotalSessions, Mode=OneWay}"
                                                 FontWeight="SemiBold" Foreground="{DynamicResource AccentPrimaryBrush}"/>
                                            <Run Text=" " Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <Run Text="{loc:Loc UI_Okter}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </TextBlock>
                                        <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="{DynamicResource AccentPrimaryBrush}"
                                                   HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
        <!-- ══ SLUTT LIST VIEW ════════════════════════════════════════════════ -->

        <!-- ══ DETAIL VIEW ════════════════════════════════════════════════════
             DetailView is a 2-row Grid:
               Row 0 — Back button (Auto)
               Row 1 — Single ScrollViewer containing ALL content in pedagogical order:
                          1. Exercise header (title, level, duration)
                          2. Short exercise description + rationale + progress
                          3. GuidancePanel          ← bridges description → steps
                          4. Step-by-step list
                          5. Timer + controls + Live Feedback
             One unified scroll region — no split panels, no visual hacks.
        -->
        <Grid x:Name="DetailView" Visibility="Collapsed" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Row 0: Back button -->
                <RowDefinition Height="*"/>      <!-- Row 1: Scrollable content column -->
            </Grid.RowDefinitions>

            <!-- ── Row 0: Navigation ──────────────────────────────────────────── -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <Button Content="{loc:Loc Exercise_Back}" Style="{StaticResource BackButton}"
                        Click="OnBackClick"/>
            </StackPanel>

            <!-- ══ Row 1: Two-column guide/session layout ═══════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*"/>
                    <ColumnDefinition Width="0.75*" MinWidth="420" MaxWidth="560"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                    <!-- ── Øvelsesinfo-kort (uendret) ─────────────────────────── -->
                    <Border Background="{DynamicResource BackgroundCardBrush}"
                            CornerRadius="16" Padding="24" Margin="0,0,0,16">
                        <Border.Effect><DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.1"/></Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="60" Height="60" CornerRadius="30"
                                        Background="{DynamicResource AccentPrimaryBrush}">
                                    <TextBlock x:Name="DetailIcon" Text="&#xE720;"
                                               FontFamily="Segoe MDL2 Assets" FontSize="30"
                                               Foreground="{DynamicResource TextOnAccentBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="DetailName" Text="{loc:Loc Exercise_NameFallback}" FontSize="24"
                                               FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Border Background="{DynamicResource InfoBrush}" CornerRadius="10" Padding="8,2">
                                            <TextBlock x:Name="DetailDifficulty"
                                                       Text="{loc:Loc Difficulty_Beginner}" FontSize="12"
                                                       Foreground="{DynamicResource TextOnAccentBrush}"/>
                                        </Border>
                                        <TextBlock x:Name="DetailDuration" Text="{loc:Loc Exercise_DefaultDuration}" FontSize="14"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock x:Name="DetailDescription" Text="{loc:Loc Exercise_DescriptionFallback}"
                                       FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,16,0,0"/>

                            <Border Background="{DynamicResource BackgroundTertiaryBrush}"
                                    CornerRadius="8" Padding="12" Margin="0,12,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="&#xE7BC;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14" Margin="0,0,8,0"
                                                   Foreground="{DynamicResource AccentPrimaryBrush}"/>
                                        <TextBlock Text="{loc:Loc Exercise_ScientificRationale}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock x:Name="DetailRationale" Text="" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- TargetPitchPanel FJERNET — ingen Hz-verdier eksponeres i UI -->

                            <Border Background="{DynamicResource BackgroundTertiaryBrush}"
                                    CornerRadius="8" Padding="12" Margin="0,16,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{loc:Loc Exercise_YourProgress}" FontSize="13"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="DetailProgress" Text="{loc:Loc Exercise_ProgressZero}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ══ EXERCISE GUIDANCE PANEL ══════════════════════════════
                         Pedagogical position: after description, before steps.
                         Bridges "what this exercise is" → "how to execute it".
                         Always visible in detail view — no Visibility binding.
                         FeedbackModeKey and all GuidanceItem text go through
                         LocConverter; no raw keys reach the UI.
                    -->
                    <Border x:Name="ExerciseGuidancePanel"
                            Background="{DynamicResource BackgroundCardBrush}"
                            CornerRadius="12" Padding="20" Margin="0,0,0,16">
                        <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1"/></Border.Effect>
                        <StackPanel>

                            <!-- Panel header with feedback-mode badge -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="&#xE7BC;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           Foreground="{DynamicResource AccentPrimaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{loc:Loc Guidance_PanelTitle}" FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Border Background="{DynamicResource AccentLightBrush}"
                                        CornerRadius="8" Padding="8,3" Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource AccentMutedBrush}"
                                               Text="{Binding FeedbackModeKey, Converter={loc:LocConverter}}"/>
                                </Border>
                            </StackPanel>

                            <!-- Data-driven guidance items — HeadingKey + BodyKey via LocConverter -->
                            <ItemsControl x:Name="GuidanceItemsList"
                                          ItemsSource="{Binding GuidanceItems}"
                                          ItemTemplate="{StaticResource GuidanceItemTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                        </StackPanel>
                    </Border>
                    <!-- ══ END GUIDANCE PANEL ════════════════════════════════════ -->

                    <!-- ── Steg-liste (uendret) ───────────────────────────────── -->
                    <TextBlock Text="{loc:Loc Exercise_StepsTitle}" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <ItemsControl x:Name="StepsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BackgroundCardBrush}"
                                        CornerRadius="8" Padding="16" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                                                Background="{DynamicResource AccentPrimaryBrush}">
                                            <TextBlock Text="{Binding Number}" FontSize="12"
                                                       Foreground="{DynamicResource TextOnAccentBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Text}" FontSize="14"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap" VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer Grid.Column="1" Margin="18,0,0,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                    <!-- ── Timer + Start/Stop (session panel) ───────────────────── -->
                    <Border Background="{DynamicResource BackgroundCardBrush}"
                            CornerRadius="12" Padding="20" Margin="0,0,0,0">
                        <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1"/></Border.Effect>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="TimerDisplay" Text="00:00" FontSize="48"
                                       FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TimerHint" Text="{loc:Loc Exercise_DefaultTimerHint}" FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,16"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="StartButton" Content="{loc:Loc UI_StartExercise}"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="OnStartClick" Margin="0,0,8,0"/>
                                <Button x:Name="StopButton" Content="{loc:Loc Exercise_Stop}"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="OnStopClick" IsEnabled="False"/>
                            </StackPanel>
                            <TextBlock x:Name="FeedbackText" Text="" FontSize="14"
                                       Foreground="{DynamicResource SuccessBrush}"
                                       HorizontalAlignment="Center" Margin="0,16,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- ══ LIVE FEEDBACK-PANEL ════════════════════════════════════
                         Synlig kun når økten er aktiv (LiveFeedbackPanel.Visibility
                         settes av code-behind i OnStartClick / OnStopClick).
                         Alle metric-verdier og synlighetsflagg speilet fra ViewModel.
                    -->
                    <Border x:Name="LiveFeedbackPanel"
                            Background="{DynamicResource BackgroundCardBrush}"
                            CornerRadius="12" Padding="20" Margin="0,16,0,0"
                            Visibility="Collapsed">
                        <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1"/></Border.Effect>
                        <StackPanel>

                            <!-- Panel header + live quality badge
                                 FIX 3: QualityLabelKey → LocConverter resolves to
                                         "Poor" / "Fair" / "Good" / "Very Good" / "Excellent".
                                         No string construction here — key arrives pre-formatted
                                         from ViewModel.QualityLabelKey.
                            -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           Foreground="{DynamicResource AccentPrimaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <!--
                                    LiveFeedback_Title key is MISSING from RESX.
                                    See missing-key log below. Using static fallback for now.
                                -->
                                <TextBlock Text="{loc:Loc LiveFeedback_Title}" FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Border HorizontalAlignment="Right" Margin="12,0,0,0"
                                        Padding="6,4" CornerRadius="8"
                                        Background="{Binding QualityBrush}">
                                    <!--
                                        FIX 3: QualityLabelKey → LocConverter.
                                        ViewModel.QualityLabelKey is one of:
                                        Quality_Poor / Quality_Fair / Quality_Good /
                                        Quality_VeryGood / Quality_Excellent — all verified in RESX.
                                    -->
                                    <TextBlock Text="{Binding QualityLabelKey, Converter={loc:LocConverter}}"
                                               Foreground="{DynamicResource TextOnAccentBrush}"
                                               FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>

                            <!-- ── A) Resonance Bar ──────────────────────────────
                                 Synlig kun når ShowResonanceBar == true
                                 Indicator_Resonance key MISSING — see log below.
                            -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="92"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" CornerRadius="8" Padding="10,8"
                                        Background="{Binding LiveCompositeScoreBrush}"
                                        Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="{loc:Loc Dashboard_Score}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextOnAccentBrush}"/>
                                        <TextBlock Text="{Binding LiveCompositeScoreText}"
                                                   FontSize="18" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextOnAccentBrush}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" CornerRadius="8" Padding="10,8"
                                        Background="{DynamicResource BackgroundTertiaryBrush}"
                                        Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="{loc:Loc LiveFeedback_Title}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding ClinicalLoopStatusKey, Converter={loc:LocConverter}}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" CornerRadius="8" Padding="10,8"
                                        Background="{DynamicResource BackgroundTertiaryBrush}">
                                    <StackPanel>
                                        <TextBlock Text="{loc:Loc Guidance_SafetyInfo}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding ProgressExplanationKey, Converter={loc:LocConverter}}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <StackPanel x:Name="ResonanceBarPanel" Margin="0,0,0,12"
                                        Visibility="{Binding ShowResonanceBar, Converter={StaticResource BoolToVisibility}}">
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc Indicator_Resonance}"
                                               Style="{StaticResource IndicatorLabel}"/>
                                    <TextBlock x:Name="ResonanceStatusText" Grid.Column="1"
                                               Text="{Binding ResonanceStatusKey, Converter={loc:LocConverter}}"
                                               Style="{StaticResource IndicatorLabel}"/>
                                </Grid>
                                <ProgressBar x:Name="ResonanceBar"
                                             Minimum="0" Maximum="1"
                                             Style="{StaticResource MetricBar}"
                                             Value="{Binding PrimaryMetricScore, Mode=OneWay}"
                                             Foreground="{Binding ResonanceBarBrush}"/>
                            </StackPanel>

                            <!-- ── B) Stability Meter ────────────────────────────
                                 Synlig kun når ShowStabilityMeter == true
                                 Indicator_Stability key MISSING — see log below.
                            -->
                            <StackPanel x:Name="StabilityPanel" Margin="0,0,0,12"
                                        Visibility="{Binding ShowStabilityMeter, Converter={StaticResource BoolToVisibility}}">
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc Indicator_Stability}"
                                               Style="{StaticResource IndicatorLabel}"/>
                                    <TextBlock x:Name="StabilityStatusText" Grid.Column="1"
                                               Text="{Binding StabilityStatusKey, Converter={loc:LocConverter}}"
                                               Style="{StaticResource IndicatorLabel}"/>
                                </Grid>
                                <ProgressBar x:Name="StabilityBar"
                                             Minimum="0" Maximum="1"
                                             Style="{StaticResource MetricBar}"
                                             Value="{Binding StabilityScore, Mode=OneWay}"
                                             Foreground="{Binding StabilityBrush}"/>
                            </StackPanel>

                            <!-- ── C) Pitch Direction ────────────────────────────
                                 Synlig kun når ShowPitchDirection == true
                                 Indicator_PitchDirection key MISSING — see log below.
                            -->
                            <StackPanel x:Name="PitchDirectionPanel" Margin="0,0,0,12"
                                        Visibility="{Binding ShowPitchDirection, Converter={StaticResource BoolToVisibility}}">
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc Indicator_PitchDirection}"
                                               Style="{StaticResource IndicatorLabel}"/>
                                    <TextBlock x:Name="PitchStatusText" Grid.Column="1"
                                               Text="{Binding PitchStatusKey, Converter={loc:LocConverter}}"
                                               Style="{StaticResource IndicatorLabel}"/>
                                </Grid>
                                <ProgressBar x:Name="PitchDirectionBar"
                                             Minimum="0" Maximum="1"
                                             Style="{StaticResource MetricBar}"
                                             Value="{Binding PitchDirectionValue, Mode=OneWay}"
                                             Foreground="{DynamicResource AccentPrimaryBrush}"/>
                            </StackPanel>

                            <!-- ── D) Airflow Indicator ──────────────────────────
                                 Synlig kun når ShowAirflowIndicator == true (straw phonation)
                                 Indicator_Airflow key MISSING — see log below.
                            -->
                            <StackPanel x:Name="AirflowPanel" Margin="0,0,0,12"
                                        Visibility="{Binding ShowAirflowIndicator, Converter={StaticResource BoolToVisibility}}">
                                <Grid Margin="0,0,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc Indicator_Airflow}"
                                               Style="{StaticResource IndicatorLabel}"/>
                                    <TextBlock x:Name="AirflowStatusText" Grid.Column="1"
                                               Text="{loc:Loc LiveFeedback_Listening}" Style="{StaticResource IndicatorLabel}"/>
                                </Grid>
                                <ProgressBar x:Name="AirflowBar"
                                             Minimum="0" Maximum="1"
                                             Style="{StaticResource MetricBar}"
                                             Foreground="{DynamicResource InfoBrush}"/>
                            </StackPanel>

                            <!-- ── E) ComfortZone Shield ─────────────────────────
                                 ShieldTextKey → LocConverter.
                                 ViewModel produces: Shield_SafetyLocked / Shield_ComfortZoneOk /
                                 Shield_OutsideComfortZone — all MISSING from RESX, see log.
                                 ShieldBrush is a Brush? property on the ViewModel resolved
                                 from the theme ResourceDictionary at runtime.
                            -->
                            <Border x:Name="ShieldPanel" CornerRadius="8" Padding="10,8"
                                    Margin="0,0,0,12"
                                    Background="{Binding ShieldBrush}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="ShieldIcon"
                                               Text="{Binding ShieldIconGlyph}"
                                               FontFamily="Segoe MDL2 Assets" FontSize="18"
                                               Foreground="{DynamicResource TextOnAccentBrush}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <!--
                                        FIX 3 (shield): ShieldTextKey → LocConverter.
                                        No hardcoded text. Key comes from ViewModel.
                                    -->
                                    <TextBlock x:Name="ShieldText"
                                               Text="{Binding ShieldTextKey, Converter={loc:LocConverter}}"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextOnAccentBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- ── F) Hold Progress Arc ──────────────────────────
                                 Synlig kun når ShowHoldProgress == true.
                                 Arc-geometri beregnes av code-behind (MirrorHoldArc).
                                 Indicator_Hold key MISSING — see log below.
                            -->
                            <StackPanel x:Name="HoldPanel"
                                        HorizontalAlignment="Center" Margin="0,0,0,12"
                                        Visibility="{Binding ShowHoldProgress, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel.Resources>
                                    <Storyboard x:Key="HoldSuccessPulse">
                                        <DoubleAnimation Storyboard.TargetName="HoldArcPath"
                                                         Storyboard.TargetProperty="StrokeThickness"
                                                         From="8" To="14" Duration="0:0:0.18" AutoReverse="True"/>
                                        <DoubleAnimation Storyboard.TargetName="HoldArcPath"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="1" To="0.75" Duration="0:0:0.18" AutoReverse="True"/>
                                    </Storyboard>
                                </StackPanel.Resources>
                                <TextBlock Text="{loc:Loc Indicator_Hold}"
                                           Style="{StaticResource IndicatorLabel}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="HoldStatusText" Text="{loc:Loc LiveFeedback_HoldStart_Tone}"
                                           Style="{StaticResource IndicatorLabel}"
                                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <Grid Width="80" Height="80">
                                    <Ellipse Width="80" Height="80"
                                             Stroke="{DynamicResource BackgroundTertiaryBrush}"
                                             StrokeThickness="8" Fill="Transparent"/>
                                    <Path x:Name="HoldArcPath"
                                          StrokeThickness="8" Fill="Transparent"
                                          Stroke="{DynamicResource SuccessBrush}"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="-90"/>
                                        </Path.RenderTransform>
                                        <Path.Data>
                                            <PathGeometry>
                                                <PathFigure x:Name="HoldArcFigure"
                                                            StartPoint="40,4" IsClosed="False">
                                                    <ArcSegment x:Name="HoldArcSegment"
                                                                Point="39.999,4"
                                                                Size="36,36"
                                                                IsLargeArc="False"
                                                                SweepDirection="Clockwise"/>
                                                </PathFigure>
                                            </PathGeometry>
                                        </Path.Data>
                                    </Path>
                                    <TextBlock x:Name="HoldPercentText" Text="0%"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <!-- ── G) Mastery badge ──────────────────────────────
                                 FIX 3: MasteryLabelKey → LocConverter.
                                 ViewModel.MasteryLabelKey is one of:
                                 Mastery_Beginner / Mastery_Developing /
                                 Mastery_Stable / Mastery_Mastered — all verified in RESX.
                            -->
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="&#xE7BC;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource AccentPrimaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding MasteryLabelKey, Converter={loc:LocConverter}}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- ── H) Inline Coach Hint ──────────────────────────
                                 Storyboard-animasjoner bevart — triggres av code-behind
                                 (MirrorCoachHint) når IsCoachMessageVisible endres.
                            -->
                            <Border x:Name="CoachHintPanel"
                                    CornerRadius="8" Padding="12,10" Margin="0,4,0,0"
                                    Background="{DynamicResource BackgroundTertiaryBrush}"
                                    Visibility="Collapsed" Opacity="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="CoachHintText"
                                               Grid.Column="0" FontSize="13"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                            FontSize="11" Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            Cursor="Hand" VerticalAlignment="Top" Margin="8,0,0,0"
                                            Click="OnDismissCoachHint"/>
                                </Grid>
                                <Border.Resources>
                                    <Storyboard x:Key="CoachFadeIn">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.35"/>
                                    </Storyboard>
                                    <Storyboard x:Key="CoachFadeOut">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </Border.Resources>
                            </Border>

                        </StackPanel>
                    </Border>
                    <!-- ══ SLUTT LIVE FEEDBACK-PANEL ═════════════════════════════ -->

                    <Border x:Name="SubjectiveReportPanel"
                            Background="{DynamicResource BackgroundCardBrush}"
                            CornerRadius="12" Padding="20" Margin="0,16,0,0"
                            Visibility="Collapsed">
                        <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1"/></Border.Effect>
                        <StackPanel>
                            <TextBlock Text="{loc:Loc SubjectiveReport_Title}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{loc:Loc SubjectiveReport_Intro}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,4,0,14"/>

                            <TextBlock Text="{loc:Loc SubjectiveReport_Comfort}"
                                       Style="{StaticResource IndicatorLabel}"
                                       Margin="0,0,0,4"/>
                            <Slider x:Name="SubjectiveComfortSlider"
                                    Minimum="1" Maximum="5" Value="4"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    TickPlacement="BottomRight" Margin="0,0,0,12"/>

                            <TextBlock Text="{loc:Loc SubjectiveReport_Fatigue}"
                                       Style="{StaticResource IndicatorLabel}"
                                       Margin="0,0,0,4"/>
                            <Slider x:Name="SubjectiveFatigueSlider"
                                    Minimum="1" Maximum="5" Value="2"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    TickPlacement="BottomRight" Margin="0,0,0,12"/>

                            <CheckBox x:Name="SubjectiveStrainCheckBox"
                                      Content="{loc:Loc SubjectiveReport_Strain}"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      Margin="0,0,0,8"/>
                            <CheckBox x:Name="SubjectiveContinueCheckBox"
                                      Content="{loc:Loc SubjectiveReport_WantsToContinue}"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      IsChecked="True" Margin="0,0,0,12"/>

                            <TextBox x:Name="SubjectiveNotesTextBox"
                                     MinHeight="58"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     ToolTip="{loc:Loc SubjectiveReport_NotesPlaceholder}"
                                     Margin="0,0,0,12"/>

                            <Button x:Name="SubmitSubjectiveReportButton"
                                    Content="{loc:Loc SubjectiveReport_Submit}"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Stretch"
                                    Click="OnSubmitSubjectiveReportClick"/>
                            <TextBlock x:Name="SubjectiveReportStatusText"
                                       Text=""
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
            <!-- ══ END SESSION SCROLLVIEWER ══════════════════════════════════════ -->

            </Grid>
            <!-- ══ END TWO-COLUMN DETAIL CONTENT ═════════════════════════════════ -->

        </Grid>
        <!-- ══ SLUTT DETAIL VIEW ════════════════════════════════════════════ -->

    </Grid>
</Window>
