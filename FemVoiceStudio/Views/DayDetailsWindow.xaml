<Window x:Class="FemVoiceStudio.Views.DayDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:FemVoiceStudio.Converters"
        xmlns:loc="clr-namespace:FemVoiceStudio.Converters"
        mc:Ignorable="d"
        Title="{loc:Loc DayDetails_Title}"
        Height="550" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundSecondaryBrush}"
        ResizeMode="CanResizeWithGrip">
    
    <Window.Resources>
        <converters:ScoreToColorConverter x:Key="ScoreToColor"/>
        
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundCardBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BackgroundCardBrush}" Padding="20,16">
            <TextBlock Text="{Binding DateDisplayText}" FontSize="20" FontWeight="SemiBold" 
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
        </Border>
        
        <!-- Summary Stats -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Sessions -->
            <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="24" 
                               HorizontalAlignment="Center" Foreground="{DynamicResource InfoBrush}"/>
                    <TextBlock Text="{Binding TotalSessions}" Style="{StaticResource StatValue}" 
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock Text="{loc:Loc Dashboard_Sessions}" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- Total Minutes -->
            <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="8,0,8,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="24" 
                               HorizontalAlignment="Center" Foreground="{DynamicResource AccentPrimaryBrush}"/>
                    <TextBlock Text="{Binding TotalMinutes}" Style="{StaticResource StatValue}" 
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock Text="{loc:Loc Dashboard_Minutes}" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- Average Score -->
            <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="8,0,8,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE735;" FontFamily="Segoe MDL2 Assets" FontSize="24" 
                               HorizontalAlignment="Center" Foreground="{DynamicResource SuccessBrush}"/>
                    <TextBlock Text="{Binding AverageScore, StringFormat={}{0:F0}%}" Style="{StaticResource StatValue}" 
                               HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource SuccessBrush}"/>
                    <TextBlock Text="{loc:Loc DayDetails_AverageScore}" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- Average Pitch -->
            <Border Grid.Column="3" Style="{StaticResource StatCard}" Margin="8,0,0,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="24" 
                               HorizontalAlignment="Center" Foreground="{DynamicResource WarningBrush}"/>
                    <TextBlock Text="{Binding AveragePitch, StringFormat={}{0:F0}}" Style="{StaticResource StatValue}" 
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock Text="{loc:Loc DayDetails_AverageHz}" Style="{StaticResource StatLabel}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Session List -->
        <Border Grid.Row="2" Style="{StaticResource StatCard}" Margin="16,0,16,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="{loc:Loc DayDetails_SessionDetails}" FontSize="16" FontWeight="SemiBold" 
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                
                <ListView Grid.Row="1" ItemsSource="{Binding Sessions}" 
                          SelectedItem="{Binding SelectedSession}"
                          Background="Transparent" BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,8"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Bd" Background="{DynamicResource BackgroundTertiaryBrush}" 
                                                CornerRadius="6" Padding="12">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" 
                                                        Value="{DynamicResource AccentPrimaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Time -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TimeDisplay}" FontSize="14" FontWeight="SemiBold" 
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding DurationDisplay}" FontSize="11" 
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                                
                                <!-- Details -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Run Text="{Binding DifficultyDisplay, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding FormantDisplay}" FontSize="10" 
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                                
                                <!-- Pitch -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Loc Dashboard_Pitch}" Style="{StaticResource StatLabel}" FontSize="10"/>
                                    <TextBlock Text="{Binding PitchDisplay}" FontSize="13" FontWeight="SemiBold" 
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                
                                <!-- Resonance -->
                                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Loc Dashboard_Resonance}" Style="{StaticResource StatLabel}" FontSize="10"/>
                                    <TextBlock Text="{Binding ResonanceDisplay}" FontSize="13" FontWeight="SemiBold" 
                                               Foreground="{DynamicResource AccentPrimaryBrush}"/>
                                </StackPanel>
                                
                                <!-- Score -->
                                <Border Grid.Column="4" CornerRadius="4" Padding="8,4" VerticalAlignment="Center"
                                        HorizontalAlignment="Right"
                                        Background="{Binding Score, Converter={StaticResource ScoreToColor}}">
                                    <TextBlock Text="{Binding ScoreDisplay}" FontSize="13" FontWeight="Bold" 
                                               Foreground="White"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                
                <!-- Empty State -->
                <TextBlock Grid.Row="1" Text="{loc:Loc DayDetails_NoSessions}" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Grid>
        </Border>
        
        <!-- Close Button -->
        <Border Grid.Row="3" Background="{DynamicResource BackgroundCardBrush}" Padding="16">
            <Button Content="{loc:Loc Common_Close}" HorizontalAlignment="Right" 
                    Click="OnCloseClick"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    MinWidth="100"/>
        </Border>
    </Grid>
</Window>
