<UserControl x:Class="FemVoiceStudio.Views.CoachDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:FemVoiceStudio.Converters"
             xmlns:converters="clr-namespace:FemVoiceStudio.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="700">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" x:Name="RootPanel">

            <!-- Header row -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Border Background="{DynamicResource AccentPrimaryBrush}"
                        CornerRadius="6" Padding="8,4" Margin="0,0,10,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="&#xE7BC;"
                               FontFamily="Segoe MDL2 Assets" FontSize="18"
                               Foreground="{DynamicResource TextOnAccentBrush}"/>
                </Border>
                <TextBlock Text="{loc:Loc Coach_Title}"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StageSummary}"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
            </StackPanel>

            <!-- Loading indicator -->
            <TextBlock Text="{loc:Loc SmartCoach_Loading}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,24,0,24"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

            <!-- No data placeholder -->
            <StackPanel HorizontalAlignment="Center" Margin="0,24,0,24"
                        Visibility="{Binding HasData, Converter={StaticResource InverseBoolToVisibility}}">
                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="{loc:Loc SmartCoach_NoData}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- ── Recovery Needs (shown first per Health > Development priority) ── -->
            <Border Background="{DynamicResource AccentWarningBrush}"
                    CornerRadius="8" Padding="12" Margin="0,0,0,12"
                    Visibility="{Binding RecoveryNeeds.Count, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Coach_RecoveryNeeds}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextOnAccentBrush}"
                               Margin="0,0,0,6"/>
                    <ItemsControl ItemsSource="{Binding RecoveryNeeds}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextOnAccentBrush}"
                                           Margin="0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ── Current Focus Areas ── -->
            <Border Background="{DynamicResource BackgroundCardBrush}"
                    CornerRadius="8" Padding="12" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.1" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{loc:Loc Coach_FocusAreas}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <!-- Empty state -->
                    <TextBlock Text="{loc:Loc SmartCoach_NoData}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontStyle="Italic"
                               Visibility="{Binding CurrentFocusAreas.Count, Converter={StaticResource InverseBoolToVisibility}}"/>
                    <ItemsControl ItemsSource="{Binding CurrentFocusAreas}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Ellipse Width="6" Height="6"
                                             Fill="{DynamicResource AccentPrimaryBrush}"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ── Exercise Recommendations ── -->
            <Border Background="{DynamicResource BackgroundCardBrush}"
                    CornerRadius="8" Padding="12" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.1" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{loc:Loc Coach_Recommendations}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{loc:Loc SmartCoach_NoData}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontStyle="Italic"
                               Visibility="{Binding ExerciseRecommendations.Count, Converter={StaticResource InverseBoolToVisibility}}"/>
                    <ItemsControl ItemsSource="{Binding ExerciseRecommendations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <TextBlock Text="&#xE8A1;"
                                               FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               Foreground="{DynamicResource AccentPrimaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ── Recent Breakthroughs ── -->
            <Border Background="{DynamicResource BackgroundCardBrush}"
                    CornerRadius="8" Padding="12" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.1" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{loc:Loc Coach_Breakthroughs}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{loc:Loc SmartCoach_NoData}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontStyle="Italic"
                               Visibility="{Binding RecentBreakthroughs.Count, Converter={StaticResource InverseBoolToVisibility}}"/>
                    <ItemsControl ItemsSource="{Binding RecentBreakthroughs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <TextBlock Text="&#xE735;"
                                               FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               Foreground="#FF4CAF50"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ── Plateau Warnings ── -->
            <Border Background="{DynamicResource BackgroundCardBrush}"
                    CornerRadius="8" Padding="12" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.1" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{loc:Loc Coach_PlateauWarnings}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{loc:Loc SmartCoach_NoData}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontStyle="Italic"
                               Visibility="{Binding PlateauWarnings.Count, Converter={StaticResource InverseBoolToVisibility}}"/>
                    <ItemsControl ItemsSource="{Binding PlateauWarnings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <TextBlock Text="&#xE7BA;"
                                               FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               Foreground="#FFFF9800"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Refresh button -->
            <Button Content="{loc:Loc Common_Refresh}"
                    Command="{Binding RefreshCommand}"
                    HorizontalAlignment="Right"
                    Padding="16,6" Margin="0,4,0,0"
                    Style="{DynamicResource PrimaryButtonStyle}"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
