<UserControl x:Class="FemVoiceStudio.Views.LiveFeedbackView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:FemVoiceStudio.Converters"
             mc:Ignorable="d"
             d:DesignHeight="180" d:DesignWidth="400">
    
    <UserControl.Resources>
        <!-- Status Circle Style -->
        <Style x:Key="StatusCircle" TargetType="Ellipse">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="StrokeThickness" Value="2"/>
        </Style>
        
        <!-- Label Style -->
        <Style x:Key="IndicatorLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    
    <Border Background="{DynamicResource BackgroundCardBrush}" 
            CornerRadius="12" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header: Health Status -->
            <Border Grid.Row="0" Background="{DynamicResource BackgroundSecondaryBrush}" 
                    CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Health Indicator -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="HealthIndicator" Width="24" Height="24" 
                                 Fill="{DynamicResource SuccessBrush}"/>
                        <TextBlock x:Name="HealthLabel" Text="{loc:Loc Health_Safe}" 
                                   FontSize="14" FontWeight="SemiBold" Margin="8,0,0,0"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Live Values -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Loc LiveFeedback_PitchLabel}" FontSize="12" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="LivePitchText" Text="-- Hz" FontSize="12" 
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="4,0,12,0"/>
                        <TextBlock Text="F2:" FontSize="12" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="LiveF2Text" Text="-- Hz" FontSize="12" 
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="4,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Status Indicators -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Resonance Status -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <Ellipse x:Name="ResonanceIndicator" Width="28" Height="28" 
                             Fill="{DynamicResource SuccessBrush}" Stroke="{DynamicResource BorderPrimaryBrush}" StrokeThickness="2"/>
                    <TextBlock Text="{loc:Loc Indicator_Resonance}" FontSize="11" 
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
                
                <!-- Pitch Status -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <Ellipse x:Name="PitchIndicator" Width="28" Height="28" 
                             Fill="{DynamicResource SuccessBrush}" Stroke="{DynamicResource BorderPrimaryBrush}" StrokeThickness="2"/>
                    <TextBlock Text="{loc:Loc Dashboard_Pitch}" FontSize="11" 
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
                
                <!-- Stability Status -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <Ellipse x:Name="StabilityIndicator" Width="28" Height="28" 
                             Fill="{DynamicResource SuccessBrush}" Stroke="{DynamicResource BorderPrimaryBrush}" StrokeThickness="2"/>
                    <TextBlock Text="{loc:Loc Indicator_Stability}" FontSize="11" 
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
                
                <!-- Intonation Status (only visible when needed) -->
                <StackPanel x:Name="IntonationPanel" Grid.Column="3" HorizontalAlignment="Center" Visibility="Collapsed">
                    <Ellipse x:Name="IntonationIndicator" Width="28" Height="28" 
                             Fill="{DynamicResource SuccessBrush}" Stroke="{DynamicResource BorderPrimaryBrush}" StrokeThickness="2"/>
                    <TextBlock Text="{loc:Loc Dashboard_Intonation}" FontSize="11" 
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
            
            <!-- Coach Hint -->
            <Border Grid.Row="2" Background="{DynamicResource BackgroundSecondaryBrush}" 
                    CornerRadius="6" Padding="12,8" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="💡" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock x:Name="CoachHintText" Grid.Column="1" 
                               Text="{loc:Loc LiveFeedback_DefaultCoachHint}"
                               FontSize="13" TextWrapping="Wrap" Margin="8,0,0,0"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
