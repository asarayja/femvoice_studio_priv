<Window x:Class="FemVoiceStudio.Views.ClinicianDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:FemVoiceStudio.Views"
        xmlns:loc="clr-namespace:FemVoiceStudio.Converters"
        mc:Ignorable="d"
        Title="{loc:Loc Nav_ClinicianDashboard}"
        Height="820" Width="860"
        MinHeight="600" MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundSecondaryBrush}">

    <!--
        DataContext is set in code-behind to ClinicianDashboardViewModel (resolved from
        App.Services). The UserControl inherits DataContext and binds all sections to it.
    -->
    <views:ClinicianDashboard x:Name="DashboardControl"/>

</Window>
