<Window x:Class="FemVoiceStudio.Views.AnalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:converters="clr-namespace:FemVoiceStudio.Converters"
        xmlns:loc="clr-namespace:FemVoiceStudio.Converters"
        mc:Ignorable="d"
        Title="{loc:Loc Analysis_Title}"
        Height="700" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundSecondaryBrush}">
    
    <Window.Resources>
        <converters:ScoreToColorConverter x:Key="ScoreToColor"/>
        <converters:DifficultyToColorConverter x:Key="DifficultyToColor"/>
        
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundCardBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ChartCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundCardBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.08" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BackgroundCardBrush}" Padding="20,16">
            <StackPanel>
                <TextBlock Text="{loc:Loc Analysis_Heading}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{loc:Loc Analysis_Subtitle}" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Top Stats Row -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Total Score -->
                    <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{loc:Loc Analysis_TotalScore}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TotalScoreText" Text="0%" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Average Pitch -->
                    <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="8,0,8,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{loc:Loc Analysis_AveragePitch}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="AvgPitchText" Text="0 Hz" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Pitch Stability -->
                    <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="8,0,8,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{loc:Loc Analysis_PitchStability}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="StabilityText" Text="0%" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Session Duration -->
                    <Border Grid.Column="3" Style="{StaticResource StatCard}" Margin="8,0,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{loc:Loc Analyzer_Duration}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="DurationText" Text="0 min" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
                
                <!-- Row 1: Resonance Analysis + Pitch Analysis -->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Resonance Analysis Chart -->
                    <Border Grid.Column="0" Style="{StaticResource ChartCard}" Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="200"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="{loc:Loc Analysis_ResonanceAnalysis}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <Border x:Name="ForwardIndicator" Background="#4CAF50" CornerRadius="4" Padding="8,2" Margin="12,0,0,0" Visibility="Collapsed">
                                    <TextBlock Text="{loc:Loc Analysis_Forward}" FontSize="11" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            
                            <oxy:PlotView Grid.Row="1" x:Name="ResonancePlotView" Background="White"/>
                        </Grid>
                    </Border>
                    
                    <!-- Pitch Analysis Chart -->
                    <Border Grid.Column="1" Style="{StaticResource ChartCard}" Margin="8,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="200"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="{loc:Loc Analysis_PitchAnalysis}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            
                            <oxy:PlotView Grid.Row="1" x:Name="PitchPlotView" Background="White"/>
                        </Grid>
                    </Border>
                </Grid>
                
                <!-- Row 2: Prosody Analysis + Health Analysis -->
                <Grid Grid.Row="2" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Prosody/Intonation Analysis -->
                    <Border Grid.Column="0" Style="{StaticResource ChartCard}" Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="200"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="{loc:Loc Analysis_IntonationAnalysis}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <Border x:Name="MonotonyIndicator" Background="#FF9800" CornerRadius="4" Padding="8,2" Margin="12,0,0,0" Visibility="Collapsed">
                                    <TextBlock Text="{loc:Loc Analysis_Monotone}" FontSize="11" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            
                            <oxy:PlotView Grid.Row="1" x:Name="IntonationPlotView" Background="White"/>
                        </Grid>
                    </Border>
                    
                    <!-- Health Analysis -->
                    <Border Grid.Column="1" Style="{StaticResource ChartCard}" Margin="8,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="200"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="{loc:Loc Analysis_HealthAnalysis}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            
                            <oxy:PlotView Grid.Row="1" x:Name="HealthPlotView" Background="White"/>
                        </Grid>
                    </Border>
                </Grid>
                
                <!-- Row 3: Score Breakdown + Session Summary -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Score Components -->
                    <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Analysis_ScoreComponents}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                            
                            <!-- Resonance Score -->
                            <StackPanel Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc Dashboard_Resonance}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="ResonanceScoreText" Grid.Column="1" Text="0%" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Grid>
                                <Grid Height="8" Margin="0,4,0,0">
                                    <Border Background="{DynamicResource BackgroundTertiaryBrush}" CornerRadius="4"/>
                                    <Border x:Name="ResonanceBar" Background="#FF6B9D" CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                                </Grid>
                            </StackPanel>
                            
                            <!-- Pitch Score -->
                            <StackPanel Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc Dashboard_Pitch}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="PitchScoreText" Grid.Column="1" Text="0%" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Grid>
                                <Grid Height="8" Margin="0,4,0,0">
                                    <Border Background="{DynamicResource BackgroundTertiaryBrush}" CornerRadius="4"/>
                                    <Border x:Name="PitchBar" Background="#4FC3F7" CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                                </Grid>
                            </StackPanel>
                            
                            <!-- Intonation Score -->
                            <StackPanel Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc Dashboard_Intonation}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="IntonationScoreText" Grid.Column="1" Text="0%" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Grid>
                                <Grid Height="8" Margin="0,4,0,0">
                                    <Border Background="{DynamicResource BackgroundTertiaryBrush}" CornerRadius="4"/>
                                    <Border x:Name="IntonationBar" Background="#81C784" CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                                </Grid>
                            </StackPanel>
                            
                            <!-- Voice Health Score -->
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Loc Dashboard_VoiceHealth}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="HealthScoreText" Grid.Column="1" Text="0%" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Grid>
                                <Grid Height="8" Margin="0,4,0,0">
                                    <Border Background="{DynamicResource BackgroundTertiaryBrush}" CornerRadius="4"/>
                                    <Border x:Name="VoiceHealthBar" Background="#FFD54F" CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Session Summary -->
                    <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Analysis_SessionSummary}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                            <TextBlock x:Name="SessionSummaryText" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
