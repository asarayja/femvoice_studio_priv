<Window x:Class="FemVoiceStudio.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:vm="clr-namespace:FemVoiceStudio.ViewModels"
        xmlns:converters="clr-namespace:FemVoiceStudio.Converters"
        xmlns:loc="clr-namespace:FemVoiceStudio.Converters"
        mc:Ignorable="d"
        Title="FemVoice Studio"
        Height="700" Width="1000"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BackgroundSecondaryBrush}">
    
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibility"/>
        <converters:PitchToColorConverter x:Key="PitchToColor" MinPitch="165" MaxPitch="255"/>
        <converters:DifficultyToColorConverter x:Key="DifficultyToColor"/>
        <converters:ScoreToColorConverter x:Key="ScoreToColor"/>
        <converters:IntensityToColorConverter x:Key="IntensityToColor"/>
        <converters:ScoreToWidthConverter x:Key="ScoreToWidthConverter"/>
        <converters:StabilityToColorConverter x:Key="StabilityToColorConverter"/>
        <converters:HealthToColorConverter x:Key="HealthToColorConverter"/>
        <converters:StabilityToTextConverter x:Key="StabilityToTextConverter"/>
        <converters:HealthToTextConverter x:Key="HealthToTextConverter"/>
        
        <!-- Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentPrimaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentSecondaryBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentTertiaryBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource BackgroundTertiaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Colored Button Styles for Main Page -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BackgroundTertiaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BackgroundHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Beginner Button - Green -->
        <Style x:Key="BeginnerButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#66BB6A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Intermediate Button - Orange -->
        <Style x:Key="IntermediateButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="#FF9800"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFB74D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Advanced Button - Red -->
        <Style x:Key="AdvancedButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="#F44336"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EF5350"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Calendar Button - Blue -->
        <Style x:Key="CalendarButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#42A5F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Statistics Button - Purple -->
        <Style x:Key="StatisticsButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="#9C27B0"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#BA68C8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Exercise Guide Button - Teal -->
        <Style x:Key="ExerciseGuideButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="#009688"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4DB6AC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Analyzer Button - Indigo -->
        <Style x:Key="AnalyzerButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="#3F51B5"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7986CB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Settings Button - Gray -->
        <Style x:Key="SettingsButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="#607D8B"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#90A4AE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Card Style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundCardBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>
        
        <!-- Main Content Area -->
        <Grid Grid.Column="0" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <StackPanel>
                        <TextBlock Text="FemVoice Studio" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{loc:Loc Main_TrainingForFeminineVoice}" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            
            <!-- Pitch Chart -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="{loc:Loc Main_PitchGraph}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <!-- A7: ingen rå Hz-verdier eksponeres i UI (samme prinsipp som
                             ExerciseWindow). Sonen kommuniseres som komfortsone-etterlevelse
                             via båndet i grafen — ikke som et tallmål å treffe. -->
                        <Border Background="{DynamicResource AccentLightBrush}" CornerRadius="4" Padding="8,4" Margin="16,0,0,0">
                            <TextBlock Text="{loc:Loc Main_ComfortZone}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>
                        
                        <!-- Stability Indicator -->
                        <Border x:Name="StabilityBorder" CornerRadius="4" Padding="8,4" Margin="12,0,0,0"
                                Background="{DynamicResource SuccessBrush}">
                            <TextBlock x:Name="StabilityText" Text="{loc:Loc Stability_Stable}" FontSize="11" Foreground="{DynamicResource TextOnAccentBrush}"/>
                        </Border>
                        
                        <!-- Health Indicator -->
                        <Border x:Name="HealthBorder" CornerRadius="4" Padding="8,4" Margin="8,0,0,0"
                                Background="{DynamicResource SuccessBrush}">
                            <TextBlock x:Name="HealthText" Text="{loc:Loc Health_Safe}" FontSize="11" Foreground="{DynamicResource TextOnAccentBrush}"/>
                        </Border>
                    </StackPanel>
                    
                    <oxy:PlotView Grid.Row="1" x:Name="PitchPlotView" 
                                  Background="{DynamicResource ChartBackgroundBrush}"
                                  MinHeight="300"/>
                </Grid>
            </Border>
            
            <!-- Mini FemVoiceScore Panel -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,16"
                    Visibility="{Binding IsRecording, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Score Header -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="{loc:Loc Dashboard_Score}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Border Background="{DynamicResource AccentPrimaryBrush}" CornerRadius="4" Padding="12,4" Margin="16,0,0,0">
                            <TextBlock Text="{Binding OverallScore, StringFormat={}{0:F0}%}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextOnAccentBrush}"/>
                        </Border>
                        <TextBlock x:Name="CoachExplanationText" Text="{Binding CoachExplanation}" FontSize="12" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="16,0,0,0" 
                                   VerticalAlignment="Center" MaxWidth="300" TextWrapping="Wrap"/>
                    </StackPanel>
                    
                    <!-- Score Bars - Equal Weight -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Resonance Score -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="{loc:Loc Dashboard_Resonance}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <Grid Height="8">
                                <Border Background="{DynamicResource BackgroundTertiaryBrush}" CornerRadius="4"/>
                                <Border x:Name="ResonanceBar" Background="{DynamicResource AccentMutedBrush}" CornerRadius="4" HorizontalAlignment="Left">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource ScoreToWidthConverter}">
                                            <Binding Path="ResonanceScore"/>
                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding ResonanceScore, StringFormat={}{0:F0}}" FontSize="12" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                        
                        <!-- Pitch Score -->
                        <StackPanel Grid.Column="1" Margin="8,0,8,0">
                            <TextBlock Text="{loc:Loc Dashboard_Pitch}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <Grid Height="8">
                                <Border Background="{DynamicResource BackgroundTertiaryBrush}" CornerRadius="4"/>
                                <Border x:Name="PitchBar" Background="{DynamicResource InfoBrush}" CornerRadius="4" HorizontalAlignment="Left">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource ScoreToWidthConverter}">
                                            <Binding Path="PitchScore"/>
                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding PitchScore, StringFormat={}{0:F0}}" FontSize="12" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                        
                        <!-- Intonation Score -->
                        <StackPanel Grid.Column="2" Margin="8,0,8,0">
                            <TextBlock Text="{loc:Loc Dashboard_Intonation}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <Grid Height="8">
                                <Border Background="{DynamicResource BackgroundTertiaryBrush}" CornerRadius="4"/>
                                <Border x:Name="IntonationBar" Background="{DynamicResource SuccessBrush}" CornerRadius="4" HorizontalAlignment="Left">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource ScoreToWidthConverter}">
                                            <Binding Path="IntonationScore"/>
                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding IntonationScore, StringFormat={}{0:F0}}" FontSize="12" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                        
                        <!-- Voice Health Score -->
                        <StackPanel Grid.Column="3" Margin="8,0,0,0">
                            <TextBlock Text="{loc:Loc Dashboard_VoiceHealth}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <Grid Height="8">
                                <Border Background="{DynamicResource BackgroundTertiaryBrush}" CornerRadius="4"/>
                                <Border x:Name="HealthScoreBar" Background="{DynamicResource WarningBrush}" CornerRadius="4" HorizontalAlignment="Left">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource ScoreToWidthConverter}">
                                            <Binding Path="VoiceHealthScore"/>
                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding VoiceHealthScore, StringFormat={}{0:F0}}" FontSize="12" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
            
            <!-- Controls -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Left side: Difficulty + Extra buttons -->
                <StackPanel Grid.Column="0">
                    <!-- Difficulty Selector -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="{loc:Loc Difficulty_Beginner}" Style="{StaticResource BeginnerButton}" 
                                Command="{Binding SetDifficultyCommand}" CommandParameter="Nybegynner" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Difficulty_Intermediate}" Style="{StaticResource IntermediateButton}" 
                                Command="{Binding SetDifficultyCommand}" CommandParameter="Middels" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Difficulty_Advanced}" Style="{StaticResource AdvancedButton}" 
                                Command="{Binding SetDifficultyCommand}" CommandParameter="Avansert"/>
                    </StackPanel>
                    
                    <!-- Extra buttons row -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="{loc:Loc Main_Calendar}" Style="{StaticResource CalendarButton}" 
                                Click="OnOpenCalendar" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Main_Statistics}" Style="{StaticResource StatisticsButton}" 
                                Click="OnOpenStatistics" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Main_ExerciseGuide}" Style="{StaticResource ExerciseGuideButton}" 
                                Click="OnOpenExerciseGuide" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Main_Analyzer}" Style="{StaticResource AnalyzerButton}" 
                                Click="OnOpenAnalyzer" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Main_SmartCoach}" Style="{StaticResource ExerciseGuideButton}" 
                                Click="OnOpenSmartCoach" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Main_Resonance}" Style="{StaticResource AnalyzerButton}" 
                                Click="OnOpenResonance" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Main_Progression}" Style="{StaticResource StatisticsButton}" 
                                Click="OnOpenProgression" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Main_Analysis}" Style="{StaticResource StatisticsButton}" 
                                Click="OnOpenAnalysis" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Main_Settings}" Style="{StaticResource SettingsButton}"
                                Click="OnOpenSettings" Margin="0,0,8,0"/>

                        <!-- Professional tools -->
                        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>
                        <Button Content="{loc:Loc Nav_ClinicianDashboard}" Style="{StaticResource StatisticsButton}"
                                Click="OnOpenClinicianDashboard" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Nav_CoachDashboard}" Style="{StaticResource StatisticsButton}"
                                Click="OnOpenCoachDashboard" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Nav_Reports}" Style="{StaticResource StatisticsButton}"
                                Click="OnOpenReportExport" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Nav_ManualOverride}" Style="{StaticResource StatisticsButton}"
                                Click="OnOpenManualOverride" Margin="0,0,8,0"/>
                        <Button Content="{loc:Loc Nav_CaseReview}" Style="{StaticResource StatisticsButton}"
                                Click="OnOpenCaseReview" Margin="0,0,8,0"/>

                        <!-- Mic Status -->
                        <Border CornerRadius="4" Padding="8,6" Background="{DynamicResource AccentLightBrush}">
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}">
                                <Run Text="🎤 "/>
                                <Run Text="{Binding StatusText}"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </StackPanel>
                
                <!-- Right side: Record Button -->
                <Button Grid.Column="1" 
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding StartRecordingCommand}"
                        Visibility="{Binding IsRecording, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                        MinWidth="150">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="12" Height="12" Fill="{DynamicResource TextOnAccentBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="{loc:Loc UI_StartSession}"/>
                    </StackPanel>
                </Button>
                
                <Button Grid.Column="1" 
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding StopRecordingCommand}"
                        Visibility="{Binding IsRecording, Converter={StaticResource BoolToVisibility}}"
                        MinWidth="150"
                        Background="{DynamicResource ErrorBrush}">
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="12" Height="12" Fill="{DynamicResource TextOnAccentBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="{loc:Loc UI_StopSession}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
        
        <!-- Right Sidebar -->
        <Border Grid.Column="1" Background="{DynamicResource BackgroundCardBrush}" BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <!-- Current Stats -->
                    <TextBlock Text="{loc:Loc Main_YourProgress}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    
                    <!-- Current Difficulty Level -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Main_CurrentLevel}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding DifficultyText}" FontSize="24" FontWeight="Bold" 
                                       Foreground="{Binding CurrentDifficulty, Converter={StaticResource DifficultyToColor}}"/>
                            <ProgressBar Value="{Binding ProgressionStatus.ProgressPercentage, FallbackValue=0, Mode=OneWay}" 
                                         Maximum="100" Height="12" Margin="0,8,0,0"
                                         Background="{DynamicResource BackgroundTertiaryBrush}" 
                                         Foreground="{DynamicResource AccentPrimaryBrush}"
                                         BorderThickness="0">
                                <ProgressBar.Template>
                                    <ControlTemplate TargetType="ProgressBar">
                                        <Grid>
                                            <Border x:Name="PART_Track" 
                                                    Background="{TemplateBinding Background}" 
                                                    CornerRadius="6"/>
                                            <Border x:Name="PART_Indicator" 
                                                    Background="{TemplateBinding Foreground}" 
                                                    CornerRadius="6" 
                                                    HorizontalAlignment="Left"/>
                                        </Grid>
                                    </ControlTemplate>
                                </ProgressBar.Template>
                            </ProgressBar>
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,0">
                                <Run Text="{Binding ProgressionStatus.SessionsAtCurrentLevel, FallbackValue=0}"/>
                                <Run Text="/"/>
                                <Run Text="{Binding ProgressionStatus.SessionsRequiredForPromotion, FallbackValue=5}"/>
                                <Run Text=" "/>
                                <Run Text="{loc:Loc Main_SessionsToNextLevel}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <!-- Streak & Sessions -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,6,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="&#xE7BC;" FontFamily="Segoe MDL2 Assets" FontSize="28" HorizontalAlignment="Center" Foreground="{DynamicResource WarningBrush}"/>
                                <TextBlock Text="{Binding CurrentStreak}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{loc:Loc Main_Streak}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="6,0,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="28" HorizontalAlignment="Center" Foreground="{DynamicResource InfoBrush}"/>
                                <TextBlock Text="{Binding TotalSessions}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{loc:Loc Main_TotalSessions}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    
                    <!-- Real-time Feedback -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,12"
                            Visibility="{Binding IsRecording, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Main_RealTimeFeedback}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding RealtimeFeedback}" FontSize="14" TextWrapping="Wrap" Margin="0,8,0,0" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            
                            <!-- Debug Info -->
                            <Border Background="{DynamicResource BackgroundTertiaryBrush}" CornerRadius="4" Padding="8,4" Margin="0,8,0,0"
                                    Visibility="{Binding DebugInfo, Converter={StaticResource StringToVisibility}}">
                                <TextBlock Text="{Binding DebugInfo}" FontSize="11" FontFamily="Consolas" Foreground="{DynamicResource SuccessBrush}"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <!-- Feedback Panel -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,12"
                            Visibility="{Binding IsRecording, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="{loc:Loc Main_Feedback}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <Border Background="{Binding OverallScore, Converter={StaticResource ScoreToColor}}" 
                                        CornerRadius="4" Padding="8,2" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding OverallScore, StringFormat={}{0:F0}%}" 
                                               Foreground="{DynamicResource TextOnAccentBrush}" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                <TextBlock Text="{Binding Feedback}" TextWrapping="Wrap" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                    
                    <!-- Exercise Text at Bottom -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="{loc:Loc Main_ExerciseText}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <Border Background="{Binding CurrentDifficulty, Converter={StaticResource DifficultyToColor}}" 
                                        CornerRadius="4" Padding="8,4" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding DifficultyText}" Foreground="{DynamicResource TextOnAccentBrush}" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                            
                            <TextBox Grid.Row="1" 
                                     Text="{Binding CurrentExerciseText, Mode=OneWay}"
                                     TextWrapping="Wrap"
                                     FontSize="16"
                                     Padding="12"
                                     BorderThickness="1"
                                     BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                     Background="{DynamicResource BackgroundTertiaryBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     MinHeight="200"
                                     MaxHeight="800"
                                     VerticalScrollBarVisibility="Auto"/>
                        </Grid>
                    </Border>
                    
                    <!-- Error Message -->
                    <Border Background="{DynamicResource ErrorBrush}" CornerRadius="4" Padding="12" Margin="0,12,0,0"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="{DynamicResource TextOnAccentBrush}" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
