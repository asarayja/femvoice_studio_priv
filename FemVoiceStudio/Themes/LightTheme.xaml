    <Color x:Key="InfoColor">#2196F3</Color>
    <Color x:Key="SuccessHoverColor">#66BB6A</Color>
    <Color x:Key="WarningHoverColor">#FFB74D</Color>
    <Color x:Key="ErrorHoverColor">#EF5350</Color>
    <Color x:Key="InfoHoverColor">#42A5F5</Color>
    <Color x:Key="HealthWarningBackgroundColor">#33FF5555</Color>
    <Color x:Key="HealthWarningTextColor">#B71C1C</Color>
