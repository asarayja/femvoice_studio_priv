<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================================================
         DARK THEME - FemVoice Studio
         Color palette and control styles for dark mode
         
         Design decisions:
         - Dark background (#1A1D28) reduces eye strain
         - Purple accent (#7A5CFF) provides modern, vibrant look
         - High contrast text ensures readability
         - Consistent key names with LightTheme for seamless switching
    ============================================================================ -->

    <!-- ============================================================================
         COLOR PALETTE
    ============================================================================ -->
    
    <!-- Background Colors - Dark theme palette -->
    <Color x:Key="BackgroundPrimaryColor">#1A1D28</Color>
    <Color x:Key="BackgroundSecondaryColor">#252836</Color>
    <Color x:Key="BackgroundTertiaryColor">#323745</Color>
    <Color x:Key="BackgroundCardColor">#252836</Color>
    <Color x:Key="BackgroundHoverColor">#3D4259</Color>
    <Color x:Key="BackgroundPressedColor">#4A5068</Color>
    
    <!-- Text Colors - High contrast for readability -->
    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#C0C0C0</Color>
    <Color x:Key="TextTertiaryColor">#8A8A8A</Color>
    <Color x:Key="TextDisabledColor">#5A5A5A</Color>
    <Color x:Key="TextOnAccentColor">#FFFFFF</Color>
    <Color x:Key="TextLinkColor">#9D7FFF</Color>
    <Color x:Key="TextLinkHoverColor">#B8A0FF</Color>
    
    <!-- Accent Colors - Purple based modern palette -->
    <Color x:Key="AccentPrimaryColor">#7A5CFF</Color>
    <Color x:Key="AccentSecondaryColor">#9D7FFF</Color>
    <Color x:Key="AccentTertiaryColor">#5A3FD9</Color>
    <Color x:Key="AccentLightColor">#3D2A70</Color>
    <Color x:Key="AccentMutedColor">#9B59B6</Color>
    
    <!-- Border Colors - Subtle dark borders -->
    <Color x:Key="BorderPrimaryColor">#323745</Color>
    <Color x:Key="BorderSecondaryColor">#4A5068</Color>
    <Color x:Key="BorderFocusColor">#7A5CFF</Color>
    <Color x:Key="BorderDisabledColor">#2A2D38</Color>
    
    <!-- Status Colors - Adjusted for dark theme visibility -->
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="WarningColor">#FFB74D</Color>
    <Color x:Key="ErrorColor">#EF5350</Color>
    <Color x:Key="InfoColor">#42A5F5</Color>
    <Color x:Key="SuccessHoverColor">#66BB6A</Color>
    <Color x:Key="WarningHoverColor">#FFD180</Color>
    <Color x:Key="ErrorHoverColor">#FF8A80</Color>
    <Color x:Key="InfoHoverColor">#64B5F6</Color>
    <Color x:Key="HealthWarningBackgroundColor">#33FF5555</Color>
    <Color x:Key="HealthWarningTextColor">#FF8888</Color>
    <!-- Quality-specific colors (subtle progression for dark theme) -->
    <Color x:Key="QualityColor_Poor">#4A2A2A</Color>
    <Color x:Key="QualityColor_Fair">#5A3E2B</Color>
    <Color x:Key="QualityColor_Good">#5A4B2A</Color>
    <Color x:Key="QualityColor_VeryGood">#2A4A36</Color>
    <Color x:Key="QualityColor_Excellent">#213A2F</Color>
    
    <!-- Chart Colors - Optimized for dark backgrounds -->
    <Color x:Key="ChartBackgroundColor">#252836</Color>
    <Color x:Key="ChartGridColor">#3D4259</Color>
    <Color x:Key="ChartTargetAreaColor">#4CAF50</Color>
    <Color x:Key="ChartPitchColor">#FF7043</Color>
    <Color x:Key="ChartResonanceColor">#FF6B9D</Color>
    <Color x:Key="ChartIntonationColor">#81C784</Color>
    <Color x:Key="ChartVoiceHealthColor">#FFD54F</Color>
    
    <!-- Dashboard/navigation semantic colors -->
    <Color x:Key="DashboardStatisticsColor">#9C27B0</Color>
    <Color x:Key="DashboardStatisticsHoverColor">#BA68C8</Color>
    <Color x:Key="DashboardGuideColor">#009688</Color>
    <Color x:Key="DashboardGuideHoverColor">#4DB6AC</Color>
    <Color x:Key="DashboardAnalyzerColor">#3F51B5</Color>
    <Color x:Key="DashboardAnalyzerHoverColor">#7986CB</Color>
    <Color x:Key="DashboardSettingsColor">#607D8B</Color>
    <Color x:Key="DashboardSettingsHoverColor">#90A4AE</Color>
    
    <!-- Analyzer/spectrogram colors -->
    <Color x:Key="AnalyzerSpectrogramLowColor">#080C16</Color>
    <Color x:Key="AnalyzerSpectrogramForwardColor">#091C1F</Color>
    <Color x:Key="AnalyzerSpectrogramHighColor">#1A1212</Color>
    <Color x:Key="AnalyzerDebugPanelColor">#333333</Color>
    <Color x:Key="AnalyzerDebugTextColor">#00FF00</Color>
    <Color x:Key="AnalyzerRangeVeryLowColor">#802020</Color>
    <Color x:Key="AnalyzerRangeLowColor">#8080FF</Color>
    <Color x:Key="AnalyzerRangeMiddleColor">#66AA66</Color>
    <Color x:Key="AnalyzerRangeUpperColor">#FF7070</Color>
    <Color x:Key="AnalyzerRangeVeryHighColor">#FFAAAA</Color>
    <Color x:Key="AnalyzerTargetLineColor">#FFD54F</Color>
    <Color x:Key="AnalyzerMainFrequencyColor">#FFFFFF</Color>
    <Color x:Key="AnalyzerForwardZoneColor">#2847D1A8</Color>
    <Color x:Key="AnalyzerF1Color">#63B3ED</Color>
    <Color x:Key="AnalyzerF2Color">#48BB78</Color>
    <Color x:Key="AnalyzerF3Color">#F6AD55</Color>
    <Color x:Key="AnalyzerSpectrogramLabelBackgroundColor">#CC000000</Color>
    
    <!-- ============================================================================
         SOLID COLOR BRUSHES
    ============================================================================ -->
    
    <!-- Background Brushes -->
    <SolidColorBrush x:Key="BackgroundPrimaryBrush" Color="{StaticResource BackgroundPrimaryColor}"/>
    <SolidColorBrush x:Key="BackgroundSecondaryBrush" Color="{StaticResource BackgroundSecondaryColor}"/>
    <SolidColorBrush x:Key="BackgroundTertiaryBrush" Color="{StaticResource BackgroundTertiaryColor}"/>
    <SolidColorBrush x:Key="BackgroundCardBrush" Color="{StaticResource BackgroundCardColor}"/>
    <SolidColorBrush x:Key="BackgroundHoverBrush" Color="{StaticResource BackgroundHoverColor}"/>
    <SolidColorBrush x:Key="BackgroundPressedBrush" Color="{StaticResource BackgroundPressedColor}"/>
    
    <!-- Text Brushes -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="{StaticResource TextOnAccentColor}"/>
    <SolidColorBrush x:Key="TextLinkBrush" Color="{StaticResource TextLinkColor}"/>
    <SolidColorBrush x:Key="TextLinkHoverBrush" Color="{StaticResource TextLinkHoverColor}"/>
    
    <!-- Accent Brushes -->
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimaryColor}"/>
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource AccentSecondaryColor}"/>
    <SolidColorBrush x:Key="AccentTertiaryBrush" Color="{StaticResource AccentTertiaryColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}"/>
    <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMutedColor}"/>
    
    <!-- Border Brushes -->
    <SolidColorBrush x:Key="BorderPrimaryBrush" Color="{StaticResource BorderPrimaryColor}"/>
    <SolidColorBrush x:Key="BorderSecondaryBrush" Color="{StaticResource BorderSecondaryColor}"/>
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource BorderFocusColor}"/>
    <SolidColorBrush x:Key="BorderDisabledBrush" Color="{StaticResource BorderDisabledColor}"/>
    
    <!-- Status Brushes -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="{StaticResource SuccessHoverColor}"/>
    <SolidColorBrush x:Key="WarningHoverBrush" Color="{StaticResource WarningHoverColor}"/>
    <SolidColorBrush x:Key="ErrorHoverBrush" Color="{StaticResource ErrorHoverColor}"/>
    <SolidColorBrush x:Key="InfoHoverBrush" Color="{StaticResource InfoHoverColor}"/>
    <SolidColorBrush x:Key="HealthWarningBackgroundBrush" Color="{StaticResource HealthWarningBackgroundColor}"/>
    <SolidColorBrush x:Key="HealthWarningTextBrush" Color="{StaticResource HealthWarningTextColor}"/>

    <SolidColorBrush x:Key="QualityBrush_Poor" Color="{StaticResource QualityColor_Poor}"/>
    <SolidColorBrush x:Key="QualityBrush_Fair" Color="{StaticResource QualityColor_Fair}"/>
    <SolidColorBrush x:Key="QualityBrush_Good" Color="{StaticResource QualityColor_Good}"/>
    <SolidColorBrush x:Key="QualityBrush_VeryGood" Color="{StaticResource QualityColor_VeryGood}"/>
    <SolidColorBrush x:Key="QualityBrush_Excellent" Color="{StaticResource QualityColor_Excellent}"/>

    <!-- Theme animation durations -->
    <sys:Double x:Key="Theme_ShortDurationSeconds">0.18</sys:Double>
    <Duration x:Key="Theme_ShortDuration">0:0:0.18</Duration>
    
    <!-- Chart Brushes -->
    <SolidColorBrush x:Key="ChartBackgroundBrush" Color="{StaticResource ChartBackgroundColor}"/>
    <SolidColorBrush x:Key="ChartGridBrush" Color="{StaticResource ChartGridColor}"/>
    <SolidColorBrush x:Key="ChartTargetAreaBrush" Color="{StaticResource ChartTargetAreaColor}"/>
    <SolidColorBrush x:Key="ChartPitchBrush" Color="{StaticResource ChartPitchColor}"/>
    <SolidColorBrush x:Key="ChartResonanceBrush" Color="{StaticResource ChartResonanceColor}"/>
    <SolidColorBrush x:Key="ChartIntonationBrush" Color="{StaticResource ChartIntonationColor}"/>
    <SolidColorBrush x:Key="ChartVoiceHealthBrush" Color="{StaticResource ChartVoiceHealthColor}"/>
    <SolidColorBrush x:Key="DashboardStatisticsBrush" Color="{StaticResource DashboardStatisticsColor}"/>
    <SolidColorBrush x:Key="DashboardStatisticsHoverBrush" Color="{StaticResource DashboardStatisticsHoverColor}"/>
    <SolidColorBrush x:Key="DashboardGuideBrush" Color="{StaticResource DashboardGuideColor}"/>
    <SolidColorBrush x:Key="DashboardGuideHoverBrush" Color="{StaticResource DashboardGuideHoverColor}"/>
    <SolidColorBrush x:Key="DashboardAnalyzerBrush" Color="{StaticResource DashboardAnalyzerColor}"/>
    <SolidColorBrush x:Key="DashboardAnalyzerHoverBrush" Color="{StaticResource DashboardAnalyzerHoverColor}"/>
    <SolidColorBrush x:Key="DashboardSettingsBrush" Color="{StaticResource DashboardSettingsColor}"/>
    <SolidColorBrush x:Key="DashboardSettingsHoverBrush" Color="{StaticResource DashboardSettingsHoverColor}"/>
    <SolidColorBrush x:Key="AnalyzerSpectrogramLowBrush" Color="{StaticResource AnalyzerSpectrogramLowColor}"/>
    <SolidColorBrush x:Key="AnalyzerSpectrogramForwardBrush" Color="{StaticResource AnalyzerSpectrogramForwardColor}"/>
    <SolidColorBrush x:Key="AnalyzerSpectrogramHighBrush" Color="{StaticResource AnalyzerSpectrogramHighColor}"/>
    <SolidColorBrush x:Key="AnalyzerDebugPanelBrush" Color="{StaticResource AnalyzerDebugPanelColor}"/>
    <SolidColorBrush x:Key="AnalyzerDebugTextBrush" Color="{StaticResource AnalyzerDebugTextColor}"/>
    <SolidColorBrush x:Key="AnalyzerRangeVeryLowBrush" Color="{StaticResource AnalyzerRangeVeryLowColor}"/>
    <SolidColorBrush x:Key="AnalyzerRangeLowBrush" Color="{StaticResource AnalyzerRangeLowColor}"/>
    <SolidColorBrush x:Key="AnalyzerRangeMiddleBrush" Color="{StaticResource AnalyzerRangeMiddleColor}"/>
    <SolidColorBrush x:Key="AnalyzerRangeUpperBrush" Color="{StaticResource AnalyzerRangeUpperColor}"/>
    <SolidColorBrush x:Key="AnalyzerRangeVeryHighBrush" Color="{StaticResource AnalyzerRangeVeryHighColor}"/>
    <SolidColorBrush x:Key="AnalyzerTargetLineBrush" Color="{StaticResource AnalyzerTargetLineColor}"/>
    <SolidColorBrush x:Key="AnalyzerMainFrequencyBrush" Color="{StaticResource AnalyzerMainFrequencyColor}"/>
    <SolidColorBrush x:Key="AnalyzerForwardZoneBrush" Color="{StaticResource AnalyzerForwardZoneColor}"/>
    <SolidColorBrush x:Key="AnalyzerF1Brush" Color="{StaticResource AnalyzerF1Color}"/>
    <SolidColorBrush x:Key="AnalyzerF2Brush" Color="{StaticResource AnalyzerF2Color}"/>
    <SolidColorBrush x:Key="AnalyzerF3Brush" Color="{StaticResource AnalyzerF3Color}"/>
    <SolidColorBrush x:Key="AnalyzerSpectrogramLabelBackgroundBrush" Color="{StaticResource AnalyzerSpectrogramLabelBackgroundColor}"/>
    
    <!-- Title Bar - Dark immersive title bar for Windows 10/11 -->
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="{StaticResource BackgroundPrimaryColor}"/>
    <SolidColorBrush x:Key="TitleBarForegroundBrush" Color="{StaticResource TextPrimaryColor}"/>

    <!-- ============================================================================
         CONTROL STYLES
         Identical key names as LightTheme for seamless switching
    ============================================================================ -->

    <!-- Primary Button Style - Purple accent -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnAccentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AccentSecondaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AccentTertiaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundTertiaryBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextDisabledBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary Button Style - Dark background -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BackgroundTertiaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="15,8"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundPressedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource TextDisabledBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger Button Style -->
    <Style x:Key="DangerButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnAccentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ErrorBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ErrorBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource BackgroundTertiaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TextBox Style - Dark input fields -->
    <Style x:Key="StandardTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style TargetType="TextBox" BasedOn="{StaticResource StandardTextBoxStyle}"/>

    <!-- CheckBox Style -->
    <Style x:Key="StandardCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- RadioButton Style -->
    <Style x:Key="StandardRadioButtonStyle" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- Card Border Style - Dark card appearance -->
    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BackgroundCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.3" Direction="270" Color="Black"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ProgressBar Style -->
    <Style x:Key="StandardProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Background" Value="{StaticResource BackgroundTertiaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
        <Setter Property="Height" Value="8"/>
    </Style>

    <!-- ComboBox Style (custom template for consistent popup and selection colors) -->
    <Style x:Key="StandardComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="SelectorBorder" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}" VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}"/>
                                <Path Data="M 0 0 L 8 0 L 4 5 Z" Fill="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Width="12" Height="8"/>
                                <ToggleButton x:Name="ToggleButton" IsChecked="{Binding IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                            </Grid>
                        </Border>

                        <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                            <Border Background="{StaticResource BackgroundCardBrush}" BorderBrush="{StaticResource BorderSecondaryBrush}" BorderThickness="1" CornerRadius="8" Padding="4">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.25" Color="#000000"/>
                                </Border.Effect>
                                <ScrollViewer CanContentScroll="True">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource TextDisabledBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="SelectorBorder" Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                            <Setter TargetName="SelectorBorder" Property="BorderBrush" Value="{StaticResource BorderFocusBrush}"/>
                        </Trigger>
                        <Trigger SourceName="ToggleButton" Property="IsMouseOver" Value="True">
                            <Setter TargetName="SelectorBorder" Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                            <Setter TargetName="SelectorBorder" Property="BorderBrush" Value="{StaticResource BorderFocusBrush}"/>
                        </Trigger>
                        <Trigger SourceName="ToggleButton" Property="IsChecked" Value="True">
                            <Setter TargetName="SelectorBorder" Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                            <Setter TargetName="SelectorBorder" Property="BorderBrush" Value="{StaticResource BorderFocusBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox" BasedOn="{StaticResource StandardComboBoxStyle}"/>

    <!-- ComboBoxItem Style with hover and selected visuals -->
    <Style x:Key="StandardComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{StaticResource BackgroundCardBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentPrimaryBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextOnAccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem" BasedOn="{StaticResource StandardComboBoxItemStyle}"/>

    <Style TargetType="DatePicker">
        <Setter Property="Background" Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- ScrollViewer Style -->
    <Style x:Key="StandardScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

</ResourceDictionary>
